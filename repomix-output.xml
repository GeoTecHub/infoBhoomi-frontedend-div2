}

.brr-metric-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 12px;
  background: var(--surface-panel-alt);
  border: 1px solid var(--border-default);
  border-radius: 10px;
  text-align: center;
  gap: 4px;
