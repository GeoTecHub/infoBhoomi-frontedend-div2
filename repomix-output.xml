<h4 mat-dialog-title>Query Builder</h4>

<div class="query-builder">
  <!-- ══ BASIC MODE (Saved Formulas) ══════════════════════════════════════════ -->
  <div class="query-basic" *ngIf="!isAdvancedMode()">
    <mat-dialog-content>
      <div *ngIf="savedFormulas().length === 0" class="empty-saved">
        <span>No saved formulas yet. Build a query in Advanced mode and save it.</span>
      </div>

      <div *ngIf="savedFormulas().length > 0">
        <label class="section-label">Saved Formulas</label>
        <div class="saved-item" *ngFor="let f of savedFormulas()">
          <div class="saved-info">
            <span class="saved-name">{{ f.name }}</span>
            <span class="saved-meta"
              >{{ getLayerLabel(f.layerId) }} · {{ f.conditions.length }} condition(s) ·
              {{ f.logic }}</span
            >
          </div>
          <div class="saved-actions">
            <button class="btn-load" (click)="loadFormula(f)">Load</button>
            <button class="btn-delete" (click)="deleteFormula(f.name)">✕</button>
          </div>
        </div>
      </div>
    </mat-dialog-content>

    <mat-dialog-actions>
      <app-custom-buttons
        buttonText="Close"
        buttonIcon="cancel"
        buttonStyle="secondary"
        (buttonClick)="onClose()"
      ></app-custom-buttons>

      <app-custom-buttons
        buttonText="Advanced"
        buttonIcon="tune"
        buttonStyle="primary"
        (buttonClick)="isAdvancedMode.set(true)"
      ></app-custom-buttons>
    </mat-dialog-actions>
  </div>

  <!-- ══ ADVANCED MODE ═════════════════════════════════════════════════════════ -->
  <div class="query-advanced" *ngIf="isAdvancedMode()">
    <mat-dialog-content>
      <!-- Layer selection -->
      <div class="form-group">
        <label>Select Layer</label>
        <select (change)="onLayerChange($any($event.target).value)">
          <option value="">-- choose layer --</option>
          <option
            *ngFor="let l of supportedLayers"
            [value]="l.id"
            [selected]="selectedLayerId() === l.id"
          >
            {{ l.label }}
          </option>
        </select>
      </div>

      <!-- Condition builder row -->
      <div class="form-group" *ngIf="selectedLayerId()">
        <label>Add Condition</label>
        <div class="condition-row">
          <select (change)="onFieldChange($any($event.target).value)">
            <option value="">-- attribute --</option>
            <option
              *ngFor="let a of availableAttributes()"
              [value]="a.field"
              [selected]="newCondition().field === a.field"
            >
              {{ a.label }}
            </option>
          </select>

          <select (change)="onOperatorChange($any($event.target).value)">
            <option
              *ngFor="let op of availableOperators()"
              [value]="op"
              [selected]="newCondition().operator === op"
            >
              {{ op === '%' ? 'LIKE' : op }}
            </option>
          </select>

          <input
            type="text"
            placeholder="value"
            [value]="newCondition().value"
            (input)="onValueChange($any($event.target).value)"
            (keydown.enter)="addCondition()"
          />

          <button class="btn-add-cond" (click)="addCondition()">+ Add</button>
        </div>
      </div>

      <!-- Conditions list -->
      <div *ngIf="conditions().length > 0">
        <div class="logic-toggle">
          <span>Combine with:</span>
          <button [class.active]="logic() === 'AND'" (click)="setLogic('AND')">AND</button>
          <button [class.active]="logic() === 'OR'" (click)="setLogic('OR')">OR</button>
        </div>

        <div class="condition-chip" *ngFor="let c of conditions(); let i = index">
          <span class="chip-text">
            {{ getAttrLabel(c.field) }}&nbsp;{{ c.operator === '%' ? 'LIKE' : c.operator }}&nbsp;{{
              c.value
            }}
          </span>
          <button class="btn-remove-cond" (click)="removeCondition(i)" title="Remove">✕</button>
        </div>
      </div>

      <!-- Formula preview -->
      <div class="form-group" *ngIf="formulaDisplay()">
        <label>Formula Preview</label>
        <textarea rows="4" readonly>{{ formulaDisplay() }}</textarea>
      </div>

      <!-- Result count -->
      <div class="result-info" *ngIf="resultCount() !== null">
        <span [class.zero]="resultCount() === 0">
          {{
            resultCount() === 0
              ? 'No features matched the query.'
              : resultCount() + ' feature(s) highlighted on map.'
          }}
        </span>
      </div>

      <!-- Save section -->
      <div class="save-section" *ngIf="conditions().length > 0">
        <input
          type="text"
          placeholder="Formula name…"
          [value]="saveQueryName()"
          (input)="saveQueryName.set($any($event.target).value)"
          (keydown.enter)="saveFormula()"
        />
        <button class="btn-save-formula" (click)="saveFormula()">Save Formula</button>
      </div>
    </mat-dialog-content>

    <mat-dialog-actions>
      <app-custom-buttons
        buttonText="Close"
        buttonIcon="cancel"
        buttonStyle="secondary"
        (buttonClick)="onClose()"
      ></app-custom-buttons>

      <app-custom-buttons
        buttonText="Saved"
        buttonIcon="bookmark"
        buttonStyle="primary"
        (buttonClick)="isAdvancedMode.set(false)"
      ></app-custom-buttons>

      <app-custom-buttons
        buttonText="Clear"
        buttonIcon="clear"
        buttonStyle="secondary"
        (buttonClick)="conditions.set([]); resultCount.set(null)"
      ></app-custom-buttons>

      <app-custom-buttons
        [buttonText]="isLoading() ? 'Running…' : 'Apply'"
        buttonIcon="check"
        buttonStyle="primary"
        (buttonClick)="applyQuery()"
      ></app-custom-buttons>
    </mat-dialog-actions>
  </div>
</div>
