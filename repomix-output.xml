/* DELETE MODAL */
#confirmDeleteModal .modal-header {
  background-color: #fff;
  /* Light red background */
  border-bottom: 1px solid #fff;
  /* Light border */
}

#confirmDeleteModal .modal-title {
  color: #721c24;
  /* Dark red text */
  font-size: 1rem;
  /* Adjust font size */
  font-weight: bold;
}

/* Close Button */
#confirmDeleteModal .btn-close {
  background-color: #df1627;
  border: none;
}

/* Modal Body */
#confirmDeleteModal .modal-body {
  background-color: #fff;
  /* Light yellow background */
  color: #856404;
  /* Dark yellow text */
}

#confirmDeleteModal .modal-body p {
  font-size: 0.9rem;
  /* Slightly smaller font */
  margin: 0;
}

/* Modal Footer */
#confirmDeleteModal .modal-footer {
  background-color: #fff;
  /* Light red footer */
}

/* Button Styles */
#confirmDeleteModal .btn-sm {
  font-size: 0.85rem;
  /* Smaller font size */
  padding: 0.5rem 1rem;
}

#confirmDeleteModal .btn-danger {
  background-color: #dc3545;
  /* Red color for the danger button */
  border: none;
}

#confirmDeleteModal .btn-secondary {
  background-color: #6c757d;
  /* Gray background for the 'No' button */
  border: none;
}

/* Button Hover Effects */
#confirmDeleteModal .btn-danger:hover {
  background-color: #c82333;
  /* Darker red on hover */
}

#confirmDeleteModal .btn-secondary:hover {
  background-color: #5a6268;
  /* Darker gray on hover */
}

