  max-width: 100%;
  height: auto;
}

/* Legend row */
.lpr-sketch-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 18px;
  margin-top: 12px;
  padding: 10px 12px;
  background: var(--surface-panel-alt);
  border: 1px solid var(--border-default);
  border-radius: 8px;
}

.lpr-sketch-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--text-primary);
}

.lpr-sketch-swatch {
  display: inline-block;
  width: 16px;
  height: 12px;
  border-radius: 2px;
  flex-shrink: 0;
}

.lpr-sketch-swatch--hatch {
  background: repeating-linear-gradient(
    -45deg,
    #9e9e9e,
    #9e9e9e 1px,
    transparent 1px,
    transparent 5px
  );
  border: 1px solid #9e9e9e;
}

/* Adjacency table */
.lpr-adj-table-wrap {
  overflow-x: auto;
  border-radius: 8px;
  border: 1px solid var(--border-default);
}

.lpr-adj-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

.lpr-adj-table thead tr {
  background: var(--surface-panel-alt);
}

.lpr-adj-table th {
  padding: 8px 12px;
  text-align: left;
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-secondary);
  white-space: nowrap;
  border-bottom: 1px solid var(--border-default);
}

.lpr-adj-table td {
  padding: 7px 12px;
  color: var(--text-primary);
  border-bottom: 1px solid var(--border-default);
}

.lpr-adj-table tbody tr:last-child td {
  border-bottom: none;
}

.lpr-adj-table tbody tr:hover td {
  background: var(--surface-sidebar-hover);
}

.lpr-adj-dir {
  font-weight: 700;
  color: var(--color-primary);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
}

.lpr-sketch-no-adj {
  padding: 12px;
  font-size: 12px;
  color: var(--text-secondary);
  text-align: center;
  font-style: italic;
}

/* ── Print Styles ── */
@media print {
  .lpr-header-right,
  .lpr-tab-bar,
  .lpr-footer {
    display: none;
  }

  .lpr-dialog {
    height: auto;
    background: white;
    color: #111;
  }

  .lpr-content {
    max-height: none !important;
    overflow: visible;
  }

  .lpr-tab-body {
    display: flex !important;
  }
}
</file>

<file path="src/app/components/dialogs/land-parcel-report/land-parcel-report.component.html">
<div
  class="lpr-dialog"
  cdkDrag
  cdkDragRootElement=".cdk-overlay-pane"
  cdkDragBoundary=".cdk-overlay-container"
>
  <!-- ═══ Header ═══ -->
  <div class="lpr-header" cdkDragHandle>
    <div class="lpr-header-left">
      <div class="lpr-header-icon">
        <mat-icon>map</mat-icon>
      </div>
      <div class="lpr-header-text">
        <h2 class="lpr-title">Land Parcel Report</h2>
        <span class="lpr-subtitle">InfoBhoomi · LADM ISO 19152</span>
      </div>
    </div>
    <div class="lpr-header-right">
      <button class="lpr-icon-btn" title="Print report" (click)="printReport()">
        <mat-icon>print</mat-icon>
      </button>
      <button class="lpr-icon-btn" title="Close" (click)="closeDialog()">
        <mat-icon>close</mat-icon>
      </button>
    </div>
  </div>

  <!-- ═══ Parcel Identity Bar ═══ -->
  <div class="lpr-identity-bar">
    <div class="lpr-identity-main">
      <span class="lpr-parcel-id">{{
        parcel.identification.parcelId || 'Feature #' + data.featureId
      }}</span>
      <span class="lpr-status-badge" [ngClass]="getStatusClass(parcel.identification.parcelStatus)">
        {{ PARCEL_STATUS_DISPLAY[parcel.identification.parcelStatus] }}
      </span>
    </div>
    <div class="lpr-identity-meta">
      <span class="lpr-meta-item">
        <mat-icon>layers</mat-icon>Layer {{ data.layerId ?? '—' }}
      </span>
      <span class="lpr-meta-item"> <mat-icon>schedule</mat-icon>Generated {{ generatedAt }} </span>
    </div>
  </div>

  <!-- ═══ Quick Stats ═══ -->
  <div class="lpr-stats-bar">
    <div class="lpr-stat">
      <span class="lpr-stat-label">Area</span>
      <span class="lpr-stat-value">{{ formatArea(parcel.spatial.area) }}</span>
    </div>
    <div class="lpr-stat-divider"></div>
    <div class="lpr-stat">
      <span class="lpr-stat-label">Land Use</span>
      <span class="lpr-stat-value">{{ LAND_USE_DISPLAY[parcel.identification.landUse] }}</span>
    </div>
    <div class="lpr-stat-divider"></div>
    <div class="lpr-stat">
      <span class="lpr-stat-label">Tenure</span>
      <span class="lpr-stat-value">{{
        TENURE_TYPE_DISPLAY[parcel.identification.tenureType]
      }}</span>
    </div>
    <div class="lpr-stat-divider"></div>
    <div class="lpr-stat">
      <span class="lpr-stat-label">Zoning</span>
      <span class="lpr-stat-value">{{ parcel.zoning.zoningCategory }}</span>
    </div>
    <div class="lpr-stat-divider"></div>
    <div class="lpr-stat">
      <span class="lpr-stat-label">Authority</span>
      <span class="lpr-stat-value">{{ parcel.identification.localAuthority || '—' }}</span>
    </div>
  </div>

  <!-- ═══ Tab Bar ═══ -->
  <div class="lpr-tab-bar">
    @for (tab of tabs; track tab.id) {
      <button
        class="lpr-tab"
        [class.lpr-tab--active]="activeTab() === tab.id"
        (click)="setActiveTab(tab.id)"
      >
        <mat-icon>{{ tab.icon }}</mat-icon>
        <span>{{ tab.label }}</span>
        @if (tab.id === 'rrr') {
          <span class="lpr-tab-badge">{{ parcel.rrr.entries.length }}</span>
        }
      </button>
    }
  </div>

  <!-- ═══ Tab Content ═══ -->
  <mat-dialog-content class="lpr-content">
    <!-- ── Overview Tab ── -->
    @if (activeTab() === 'overview') {
      <div class="lpr-tab-body">
        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>badge</mat-icon></div>
            <div>
              <div class="lpr-section-title">Identification</div>
              <div class="lpr-section-sub">LADM LA_BAUnit reference data</div>
            </div>
          </div>
          <div class="lpr-field-grid lpr-field-grid--3">
            <div class="lpr-field">
              <span class="lpr-field-label">Parcel ID</span>
              <span class="lpr-field-value lpr-mono lpr-highlight">{{
                parcel.identification.parcelId || '—'
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Cadastral Reference</span>
              <span class="lpr-field-value lpr-mono">{{
                parcel.identification.cadastralRef || '—'
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Registration Date</span>
              <span class="lpr-field-value lpr-mono">{{
                formatDate(parcel.identification.registrationDate)
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Parcel Type</span>
              <span class="lpr-field-value">{{
                PARCEL_TYPE_DISPLAY[parcel.identification.parcelType]
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Status</span>
              <span class="lpr-field-value">{{
                PARCEL_STATUS_DISPLAY[parcel.identification.parcelStatus]
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Local Authority</span>
              <span class="lpr-field-value">{{ parcel.identification.localAuthority || '—' }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Land Use</span>
              <span class="lpr-field-value">{{
                LAND_USE_DISPLAY[parcel.identification.landUse]
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Tenure Type</span>
              <span class="lpr-field-value">{{
                TENURE_TYPE_DISPLAY[parcel.identification.tenureType]
              }}</span>
            </div>
          </div>
        </div>

        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>place</mat-icon></div>
            <div>
              <div class="lpr-section-title">Location</div>
              <div class="lpr-section-sub">Centroid coordinates &amp; geometry</div>
            </div>
          </div>
          <div class="lpr-field-grid lpr-field-grid--3">
            <div class="lpr-field">
              <span class="lpr-field-label">Centroid Longitude</span>
              <span class="lpr-field-value lpr-mono">{{
                formatCoord(parcel.spatial.centroidLon)
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Centroid Latitude</span>
              <span class="lpr-field-value lpr-mono">{{
                formatCoord(parcel.spatial.centroidLat)
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">CRS</span>
              <span class="lpr-field-value lpr-mono">{{ parcel.spatial.crs }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Area</span>
              <span class="lpr-field-value lpr-mono lpr-highlight">{{
                formatAreaM2(parcel.spatial.area)
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Perimeter</span>
              <span class="lpr-field-value lpr-mono">{{
                parcel.spatial.perimeter ? (parcel.spatial.perimeter | number: '1.2-2') + ' m' : '—'
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Geometry Type</span>
              <span class="lpr-field-value lpr-mono">{{ parcel.spatial.geometryType }}</span>
            </div>
          </div>
        </div>

        @if (
          parcel.relationships.buildingIds?.length ||
          parcel.relationships.adjacentParcels ||
          parcel.relationships.parentParcel
        ) {
          <div class="lpr-section">
            <div class="lpr-section-header">
              <div class="lpr-section-icon"><mat-icon>account_tree</mat-icon></div>
              <div>
                <div class="lpr-section-title">Relationships</div>
                <div class="lpr-section-sub">Linked buildings &amp; parcels</div>
              </div>
            </div>
            <div class="lpr-field-grid lpr-field-grid--2">
              @if (parcel.relationships.buildingIds?.length) {
                <div class="lpr-field lpr-field--wide">
                  <span class="lpr-field-label">Buildings on Parcel</span>
                  <span class="lpr-field-value lpr-mono">{{
                    parcel.relationships.buildingIds.join(', ')
                  }}</span>
                </div>
              }
              @if (parcel.relationships.adjacentParcels) {
                <div class="lpr-field lpr-field--wide">
                  <span class="lpr-field-label">Adjacent Parcels</span>
                  <span class="lpr-field-value lpr-mono">{{
                    parcel.relationships.adjacentParcels
                  }}</span>
                </div>
              }
              @if (parcel.relationships.parentParcel) {
                <div class="lpr-field">
                  <span class="lpr-field-label">Parent Parcel</span>
                  <span class="lpr-field-value lpr-mono">{{
                    parcel.relationships.parentParcel
                  }}</span>
                </div>
              }
              @if (parcel.relationships.partOfEstate) {
                <div class="lpr-field">
                  <span class="lpr-field-label">Estate / Complex</span>
                  <span class="lpr-field-value lpr-mono">{{
                    parcel.relationships.partOfEstate
                  }}</span>
                </div>
              }
            </div>
          </div>
        }
      </div>
    }

    <!-- ── Spatial Tab ── -->
    @if (activeTab() === 'spatial') {
      <div class="lpr-tab-body">
        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>straighten</mat-icon></div>
            <div>
              <div class="lpr-section-title">Spatial Metrics</div>
              <div class="lpr-section-sub">Computed from OpenLayers geometry</div>
            </div>
          </div>
          <div class="lpr-metric-cards">
            <div class="lpr-metric-card lpr-metric-card--accent">
              <span class="lpr-metric-label">Total Area</span>
              <span class="lpr-metric-value">{{ formatAreaM2(parcel.spatial.area) }}</span>
              <span class="lpr-metric-sub">{{ formatArea(parcel.spatial.area) }}</span>
            </div>
            <div class="lpr-metric-card">
              <span class="lpr-metric-label">Perimeter</span>
              <span class="lpr-metric-value">{{
                parcel.spatial.perimeter ? (parcel.spatial.perimeter | number: '1.1-1') + ' m' : '—'
              }}</span>
            </div>
            <div class="lpr-metric-card">
              <span class="lpr-metric-label">Vertices</span>
              <span class="lpr-metric-value">{{ parcel.spatial.coordinateCount || '—' }}</span>
            </div>
          </div>
          <div class="lpr-field-grid lpr-field-grid--3" style="margin-top: 16px">
            <div class="lpr-field">
              <span class="lpr-field-label">Geometry Type</span>
              <span class="lpr-field-value lpr-mono">{{ parcel.spatial.geometryType }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Boundary Type</span>
              <span class="lpr-field-value">{{
                BOUNDARY_TYPE_DISPLAY[parcel.spatial.boundaryType]
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">CRS</span>
              <span class="lpr-field-value lpr-mono">{{ parcel.spatial.crs }}</span>
            </div>
          </div>
        </div>

        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>my_location</mat-icon></div>
            <div>
              <div class="lpr-section-title">Centroid Coordinates</div>
              <div class="lpr-section-sub">Geographic centre of the parcel boundary</div>
            </div>
          </div>
          <div class="lpr-coord-display">
            <div class="lpr-coord-row">
              <div class="lpr-coord-badge">LON</div>
              <span class="lpr-coord-value">{{ formatCoord(parcel.spatial.centroidLon) }}</span>
            </div>
            <div class="lpr-coord-row">
              <div class="lpr-coord-badge">LAT</div>
              <span class="lpr-coord-value">{{ formatCoord(parcel.spatial.centroidLat) }}</span>
            </div>
          </div>
        </div>

        <!-- ── Cadastral Sketch ── -->
        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>crop_free</mat-icon></div>
            <div>
              <div class="lpr-section-title">Cadastral Sketch</div>
              <div class="lpr-section-sub">
                To-scale reference diagram — not for legal survey use
              </div>
            </div>
          </div>

          @if (sketchBuilding()) {
            <div class="lpr-sketch-loading">
              <div class="lpr-sketch-spinner"></div>
              <span>Building cadastral sketch…</span>
            </div>
          }

          @if (sketchError()) {
            <div class="lpr-sketch-error">
              <mat-icon>warning</mat-icon>
              <span>{{ sketchError() }}</span>
            </div>
          }

          @if (sketchData(); as sketch) {
            <!-- SVG Sketch -->
            <div class="lpr-sketch-svg-wrap">
              <svg
                [attr.width]="sketch.svgW"
                [attr.height]="sketch.svgH"
                [attr.viewBox]="'0 0 ' + sketch.svgW + ' ' + sketch.svgH"
                class="lpr-sketch-svg"
                xmlns="http://www.w3.org/2000/svg"
              >
                <defs>
                  <!-- Road / access hatch pattern -->
                  <pattern id="lprRoadHatch" patternUnits="userSpaceOnUse" width="7" height="7">
                    <line x1="0" y1="7" x2="7" y2="0" stroke="#9e9e9e" stroke-width="1.5" />
                  </pattern>
                </defs>

                <!-- Paper background -->
                <rect
                  x="0"
                  y="0"
                  [attr.width]="sketch.svgW"
                  [attr.height]="sketch.svgH"
                  fill="#f5f9f6"
                />

                <!-- Neighbour parcels (drawn first, behind selected) -->
                @for (p of sketch.parcels; track p.id) {
                  @if (!p.isSelected) {
                    <polygon
                      [attr.points]="p.points"
                      [attr.fill]="p.fill"
                      [attr.stroke]="p.stroke"
                      stroke-width="1.2"
                      stroke-linejoin="round"
                    />
                  }
                }

                <!-- Selected parcel (on top) -->
                @for (p of sketch.parcels; track p.id) {
                  @if (p.isSelected) {
                    <polygon
                      [attr.points]="p.points"
                      [attr.fill]="p.fill"
                      [attr.stroke]="p.stroke"
                      stroke-width="2"
                      stroke-linejoin="round"
                    />
                  }
                }

                <!-- Road access strip -->
                @if (sketch.hasRoad) {
                  <rect
                    [attr.x]="sketch.roadX"
                    [attr.y]="sketch.roadY"
                    [attr.width]="sketch.roadW"
                    [attr.height]="sketch.roadH"
                    fill="url(#lprRoadHatch)"
                    stroke="#9e9e9e"
                    stroke-width="1"
                  />
                  <text
                    [attr.x]="sketch.roadX + sketch.roadW / 2"
                    [attr.y]="sketch.roadY + sketch.roadH + 10"
                    text-anchor="middle"
                    font-size="8"
                    fill="#757575"
                    font-family="sans-serif"
                  >
                    Road Access
                  </text>
                }

                <!-- Parcel labels (ID + area) -->
                @for (p of sketch.parcels; track p.id) {
                  <text
                    [attr.x]="p.textX"
                    [attr.y]="p.textY - 5"
                    text-anchor="middle"
                    dominant-baseline="middle"
                    font-size="9"
                    font-weight="700"
                    [attr.fill]="p.isSelected ? '#0d3c7a' : '#37474f'"
                    font-family="monospace"
                  >
                    {{ p.idLine }}
                  </text>
                  <text
                    [attr.x]="p.textX"
                    [attr.y]="p.textY + 8"
                    text-anchor="middle"
                    dominant-baseline="middle"
                    font-size="8"
                    [attr.fill]="p.isSelected ? '#1565c0' : '#546e7a'"
                    font-family="sans-serif"
                  >
                    {{ p.areaLine }}
                  </text>
                }

                <!-- Scale bar -->
                <rect
                  [attr.x]="sketch.scaleBarX"
                  [attr.y]="sketch.scaleBarY - 5"
                  [attr.width]="sketch.scaleBarW / 2"
                  height="5"
                  fill="#37474f"
                />
                <rect
                  [attr.x]="sketch.scaleBarX + sketch.scaleBarW / 2"
                  [attr.y]="sketch.scaleBarY - 5"
                  [attr.width]="sketch.scaleBarW / 2"
                  height="5"
                  fill="white"
                  stroke="#37474f"
                  stroke-width="0.8"
                />
                <line
                  [attr.x1]="sketch.scaleBarX"
                  [attr.y1]="sketch.scaleBarY - 10"
                  [attr.x2]="sketch.scaleBarX"
                  [attr.y2]="sketch.scaleBarY"
                  stroke="#37474f"
                  stroke-width="1"
                />
                <line
                  [attr.x1]="sketch.scaleBarX + sketch.scaleBarW"
                  [attr.y1]="sketch.scaleBarY - 10"
                  [attr.x2]="sketch.scaleBarX + sketch.scaleBarW"
                  [attr.y2]="sketch.scaleBarY"
                  stroke="#37474f"
                  stroke-width="1"
                />
                <text
                  [attr.x]="sketch.scaleBarX"
                  [attr.y]="sketch.scaleBarY + 8"
                  font-size="8"
                  fill="#546e7a"
                  font-family="sans-serif"
                >
                  0
                </text>
                <text
                  [attr.x]="sketch.scaleBarX + sketch.scaleBarW"
                  [attr.y]="sketch.scaleBarY + 8"
                  text-anchor="end"
                  font-size="8"
                  fill="#546e7a"
                  font-family="sans-serif"
                >
                  {{ sketch.scaleBarLabel }}
                </text>
                <!-- North arrow (top-right) -->
                <g [attr.transform]="'translate(' + sketch.northX + ',' + sketch.northY + ')'">
                  <polygon points="0,-16 -5,5 0,2 5,5" fill="#37474f" />
                  <polygon
                    points="0,-16 5,5 0,2 -5,5"
                    fill="white"
                    stroke="#37474f"
                    stroke-width="0.8"
                  />
                  <text
                    x="0"
                    y="22"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#37474f"
                    font-family="sans-serif"
                  >
                    N
                  </text>
                </g>

                <!-- Frame border -->
                <rect
                  x="1"
                  y="1"
                  [attr.width]="sketch.svgW - 2"
                  [attr.height]="sketch.svgH - 2"
                  fill="none"
                  stroke="#b0bec5"
                  stroke-width="1"
                />
              </svg>
            </div>

            <!-- Legend -->
            <div class="lpr-sketch-legend">
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: rgba(21, 101, 192, 0.2); border: 2px dashed #1565c0"
                ></span>
                <span>Selected Parcel</span>
              </div>
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: #b2dfdb; border: 1px solid #00796b"
                ></span>
                <span>Residential</span>
              </div>
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: #fff59d; border: 1px solid #f9a825"
                ></span>
                <span>Commercial</span>
              </div>
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: #c8e6c9; border: 1px solid #388e3c"
                ></span>
                <span>Agricultural</span>
              </div>
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: #ffccbc; border: 1px solid #bf360c"
                ></span>
                <span>Industrial</span>
              </div>
              <div class="lpr-sketch-legend-item">
                <span
                  class="lpr-sketch-swatch"
                  style="background: #e1bee7; border: 1px solid #7b1fa2"
                ></span>
                <span>Mixed Use</span>
              </div>
              @if (sketchData()!.hasRoad) {
                <div class="lpr-sketch-legend-item">
                  <span class="lpr-sketch-swatch lpr-sketch-swatch--hatch"></span>
                  <span>Road Access</span>
                </div>
              }
            </div>

            <!-- Adjacency Table -->
            @if (adjRows().length) {
              <div
                class="lpr-section-sub"
                style="
                  margin-top: 16px;
                  margin-bottom: 8px;
                  font-size: 11px;
                  font-weight: 700;
                  text-transform: uppercase;
                  letter-spacing: 0.4px;
                "
              >
                Adjoining Parcels ({{ adjRows().length }})
              </div>
              <div class="lpr-adj-table-wrap">
                <table class="lpr-adj-table">
                  <thead>
                    <tr>
                      <th>Direction</th>
                      <th>Parcel ID</th>
                      <th>Land Use</th>
                      <th>Area (m²)</th>
                      <th>Area (Acres)</th>
                    </tr>
                  </thead>
                  <tbody>
                    @for (row of adjRows(); track row.id) {
                      <tr>
                        <td class="lpr-adj-dir">{{ row.direction }}</td>
                        <td class="lpr-mono">{{ row.id }}</td>
                        <td>{{ row.landUse }}</td>
                        <td class="lpr-mono">{{ row.areaM2 | number }}</td>
                        <td class="lpr-mono">{{ row.areaAcres }}</td>
                      </tr>
                    }
                  </tbody>
                </table>
              </div>
            } @else {
              <div class="lpr-sketch-no-adj">No adjoining parcels found within 50 m buffer.</div>
            }
          }
        </div>
      </div>
    }

    <!-- ── Land & Physical Tab ── -->
    @if (activeTab() === 'land') {
      <div class="lpr-tab-body">
        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>landscape</mat-icon></div>
            <div>
              <div class="lpr-section-title">Physical Characteristics</div>
              <div class="lpr-section-sub">Environmental &amp; terrain data</div>
            </div>
          </div>
          <div class="lpr-field-grid lpr-field-grid--3">
            <div class="lpr-field">
              <span class="lpr-field-label">Elevation</span>
              <span class="lpr-field-value lpr-mono">{{
                parcel.physical.elevation ? parcel.physical.elevation + ' m MSL' : '—'
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Slope</span>
              <span class="lpr-field-value lpr-mono">{{
                parcel.physical.slope ? parcel.physical.slope + '°' : '—'
              }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Soil Type</span>
              <span class="lpr-field-value">{{ SOIL_TYPE_DISPLAY[parcel.physical.soilType] }}</span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Flood Zone</span>
              <span class="lpr-field-value" [class.lpr-warning]="parcel.physical.floodZone">
                {{ parcel.physical.floodZone ? 'Yes — Flood Risk' : 'No' }}
              </span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Road Access</span>
              <span class="lpr-field-value" [class.lpr-success]="parcel.physical.accessRoad">
                {{ parcel.physical.accessRoad ? 'Available' : 'No Access' }}
              </span>
            </div>
            <div class="lpr-field">
              <span class="lpr-field-label">Vegetation Cover</span>
              <span class="lpr-field-value">{{ parcel.physical.vegetationCover || '—' }}</span>
            </div>
          </div>
          <div class="lpr-utilities-row">
            <span class="lpr-field-label">Utilities</span>
            <div class="lpr-tag-list">
              @if (parcel.physical.waterSupply) {
                <span class="lpr-tag"><mat-icon>check_circle</mat-icon>Water Supply</span>
              }
              @if (parcel.physical.electricity) {
                <span class="lpr-tag"><mat-icon>check_circle</mat-icon>Electricity</span>
              }
              @if (parcel.physical.drainageSystem) {
                <span class="lpr-tag"><mat-icon>check_circle</mat-icon>Drainage</span>
              }
              @if (parcel.physical.sanitationGully) {
                <span class="lpr-tag"><mat-icon>check_circle</mat-icon>Sanitation Gully</span>
              }
              @if (parcel.physical.garbageDisposal) {
                <span class="lpr-tag"><mat-icon>check_circle</mat-icon>Garbage Disposal</span>
              }
            </div>
          </div>
        </div>
      </div>
    }

    <!-- ── Zoning Tab ── -->
    @if (activeTab() === 'zoning') {
      <div class="lpr-tab-body">
        <div class="lpr-section">
          <div class="lpr-section-header">
            <div class="lpr-section-icon"><mat-icon>domain</mat-icon></div>
            <div>
              <div class="lpr-section-title">Zoning Classification</div>
              <div class="lpr-section-sub">Planning &amp; development controls</div>
            </div>
          </div>
          <div class="lpr-zoning-banner">
            <span class="lpr-zoning-code">{{ parcel.zoning.zoningCategory }}</span>
            <span class="lpr-zoning-desc">{{
