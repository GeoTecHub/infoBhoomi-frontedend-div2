  color: var(--color-error);
  border: 1px solid rgba(220, 53, 69, 0.3);
  flex: 0 0 auto;
}

.delete-btn:hover {
  background: rgba(220, 53, 69, 0.2);
}

/* RRR Actions Cell */
.rrr-actions-cell {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.rrr-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  border: 1px solid var(--border-default);
  border-radius: 4px;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s;
}

.rrr-expand-btn:hover {
  background: rgba(40, 167, 69, 0.1);
  color: var(--color-success);
}

.rrr-expand-btn.expanded {
  background: rgba(40, 167, 69, 0.08);
  color: var(--color-success);
}

.rrr-expand-btn.expanded svg {
  transform: rotate(180deg);
}

.rrr-expand-btn svg {
  transition: transform 0.2s ease;
}

/* Document Section */
.rrr-documents-section {
  margin-top: 0.5rem;
  padding-top: 0.5rem;
  border-top: 1px solid var(--border-default);
}

.rrr-upload-btn {
  font-size: 0.65rem;
  padding: 0.15rem 0.4rem;
  border: 1px solid rgba(40, 167, 69, 0.3);
  border-radius: 4px;
  background: transparent;
  color: var(--color-success);
  cursor: pointer;
  transition: all 0.15s;
}

.rrr-upload-btn:hover {
  background: rgba(40, 167, 69, 0.1);
}

.rrr-doc-chip {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.25rem 0.4rem;
  margin-bottom: 0.25rem;
  background: var(--surface-panel);
  border: 1px solid var(--border-default);
  border-radius: 6px;
  font-size: 0.7rem;
  color: var(--text-primary);
}

.rrr-doc-chip svg {
  flex-shrink: 0;
  color: var(--text-secondary);
}

.doc-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.doc-size {
  color: var(--text-secondary);
  font-size: 0.65rem;
  flex-shrink: 0;
}

/* Responsive */
@media (max-width: 1200px) {
  .land-panel {
    min-width: 280px;
  }
}

/* Read-only section: visually disable all inputs when role lacks edit permission */
.section-readonly input,
.section-readonly select,
.section-readonly textarea {
  pointer-events: none;
  background-color: var(--color-background-l1, #f5f5f5);
  color: var(--color-text-secondary, #888);
  cursor: not-allowed;
  opacity: 0.75;
}

.section-readonly button:not(.section-header) {
  pointer-events: none;
  opacity: 0.5;
}
