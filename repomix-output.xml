                <form [formGroup]="userForm" class="w-100 px-4">
                  <div class="row">
                    <!-- Username -->
                    <div class="form-group mb-3 col-md-6">
                      <label for="username">Username</label>
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        id="username"
                        placeholder="Enter Username"
