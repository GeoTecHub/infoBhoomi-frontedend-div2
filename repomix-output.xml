                <div class="d-flex align-items-center">
                  <span
                    class="bg-opacity-10 rounded-circle p-2 me-2 d-flex align-items-center justify-content-center"
                    style="width: 30px; height: 30px; background-color: #a813a8"
                  >
                    <i class="bi bi-person-plus-fill text-white fs-6"></i>
                  </span>
                  <span class="flex-grow-1">Registered</span>
                  <span class="fw-bold fs-4">{{ registeredUsers }}</span>
                </div>
              </div>
            </div>
          </div>
          <!-- Recent Activities -->
          <div class="col-md-9">
            <div class="card h-100 shadow-sm py-3">
              <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: #3c71a6">Recent Logins</h5>
                <table class="table table-sm mb-0 table-striped">
                  <thead>
                    <tr>
                      <th class="f-14" scope="col">Username</th>
                      <th class="f-14" scope="col">Email</th>
                      <th class="f-14" scope="col">Name</th>
                      <th class="f-14" scope="col">Department</th>
                      <th class="f-14 text-center" scope="col">Type</th>
                      <th class="f-14" scope="col">Time</th>
                    </tr>
                  </thead>
                  <tbody>
                    @for (login of logins; track login) {
                      <tr>
                        <td class="f-12">{{ login.username }}</td>
                        <td class="f-12">{{ login.email }}</td>
                        <td class="f-12">{{ login.first_name + ' ' + login.last_name }}</td>
                        <td class="f-12">{{ login.department }}</td>
                        <td class="f-12">
                          <div
                            [ngClass]="
                              login.user_type === 'admin'
                                ? 'admin-pill'
                                : login.user_type === 'user'
                                  ? 'user-pill'
                                  : !login.is_active
                                    ? 'disabled-pill'
                                    : ''
                            "
                          >
                            {{ login.user_type }}
                          </div>
                        </td>
                        <td class="text-muted small f-12">
                          {{
                            login.last_login
                              ? (login.last_login | date: 'dd/MM/yyyy h:mm:ss a')
                              : ''
                          }}
                        </td>
                      </tr>
                    }
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
