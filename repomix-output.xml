                  </span>
                  <span class="fw-bold fs-4">{{ onlineUsers }}</span>
                </div>
                <div class="d-flex align-items-center mb-3">
                  <span
                    class="bg-opacity-10 rounded-circle p-2 me-2 d-flex align-items-center justify-content-center"
                    style="width: 30px; height: 30px; background-color: #f2312b"
