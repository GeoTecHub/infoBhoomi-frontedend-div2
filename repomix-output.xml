<div class="min-vh-100 bg-body">
  <!-- Hero Section -->
  <section
    class="position-relative min-vh-100 d-flex align-items-center justify-content-center overflow-hidden"
  >
    <div class="position-absolute top-0 start-0 end-0 bottom-0 z-0 hero-gradient">
      <div
        class="position-absolute top-0 start-0 end-0 bottom-0 hero-map-overlay"
        [ngStyle]="{ 'background-image': 'url(' + heroMap + ')' }"
      ></div>
    </div>

    <div class="position-relative z-1 container py-7 text-center">
      <div class="mx-auto" style="max-width: 64rem">
        <div class="d-inline-block px-3 py-2 bg-badge rounded-pill border badge-border mb-3">
          <span class="small fw-medium text-badge">{{ hero.badge }}</span>
        </div>

        <h1 class="display-4 fw-bold text-hero mb-3">
          {{ hero.title }}
        </h1>

        <p class="lead text-hero-90 mx-auto" style="max-width: 48rem">
          {{ hero.subtitle }}
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center pt-4">
          <a href="/login">
            <button class="btn btn-accent btn-lg px-4 py-3 d-flex align-items-center">
              Try InfoBhoomi
              <mat-icon class="ms-2">arrow_forward</mat-icon>
            </button>
          </a>

          <button class="btn btn-outline-light btn-lg px-4 py-3 bg-blur border-hero">
            View Technical Blueprint
          </button>
        </div>
      </div>
    </div>

    <div class="position-absolute bottom-0 start-0 end-0 hero-bottom-fade z-1"></div>
  </section>

  <section>
    <div class="container">
      <div class="logo-hldr text-center">
        <img class="img-fluid" src="logos/LOGO.svg" alt="" />
      </div>
    </div>
  </section>

  <!-- Challenge & Solution -->
  <section class="py-7 bg-body">
    <div class="container">
      <div class="mx-auto text-center mb-16" style="max-width: 56rem">
        <h2 class="display-6 fw-bold text-body mb-2">From Fragmentation to Integration</h2>
        <p class="fs-5 text-muted">
          Transforming disconnected data silos into a unified spatial intelligence platform
        </p>
      </div>

      <div class="row g-4">
        <div class="col-md-6">
          <div class="card h-100 border-danger-subtle bg-danger-soft p-5">
            <div class="d-flex align-items-center gap-3 mb-4">
              <div class="p-3 bg-danger-subtle bg-destruct-low rounded d-flex">
                <mat-icon class="text-danger fs-5 mt-1">storage</mat-icon>
              </div>
              <h3 class="h4 fw-bold mb-0">The Challenge</h3>
            </div>
            <ul class="list-unstyled m-0">
              @for (item of challengeList; track item) {
                <li class="d-flex gap-3 mb-2">
                  <span class="dot-danger mt-2"></span>
                  <span class="text-muted">{{ item }}</span>
                </li>
              }
            </ul>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card h-100 border-accent-subtle bg-accent-soft p-5">
            <div class="d-flex align-items-center gap-3 mb-4">
              <div class="p-3 bg-accent-subtle rounded bg-success-low d-flex">
                <mat-icon class="text-accent fs-5 mt-1">share</mat-icon>
              </div>
              <h3 class="h4 fw-bold mb-0">The InfoBhoomi Solution</h3>
            </div>
            <ul class="list-unstyled m-0">
              @for (item of solutionList; track item) {
                <li class="d-flex gap-3 mb-2">
                  <mat-icon class="text-accent mt-1">check_circle</mat-icon>
                  <span class="text-muted">{{ item }}</span>
                </li>
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Functions -->
  <section class="py-7 bg-muted-30">
    <div class="container">
      <div class="mx-auto text-center mb-16" style="max-width: 56rem">
        <h2 class="display-6 fw-bold text-body mb-2">Core Functions and Data Integration</h2>
        <p class="fs-5 text-muted">
          InfoBhoomi functions as a Local Authority-level land information management system built
          upon six key components
        </p>
      </div>

      <div class="row g-4">
        @for (c of coreFunctions; track c) {
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 border p-4 hover-shadow">
              <div class="p-3 bg-primary-soft rounded mb-3 d-inline-flex w-56px">
                <mat-icon class="fs-4 text-primary i-dark">{{ c.icon }}</mat-icon>
              </div>
              <h3 class="h5 fw-bold">{{ c.title }}</h3>
              <p class="text-muted mb-3">{{ c.description }}</p>
              <div class="pt-3 border-top">
                <p class="small text-muted fw-semibold m-0">{{ c.source }}</p>
              </div>
            </div>
          </div>
        }
      </div>
    </div>
