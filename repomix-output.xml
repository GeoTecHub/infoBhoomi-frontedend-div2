}

// Default style for drawing
const defaultDrawStyle = new Style({
  stroke: new Stroke({ color: 'rgba(0, 153, 255, 0.9)', width: 3 }), // Bright blue
  fill: new Fill({ color: 'rgba(0, 153, 255, 0.2)' }),
