import { Component, OnInit, ChangeDetectionStrategy, ChangeDetectorRef, inject } from '@angular/core';
import { FormsModule } from '@angular/forms';
import { MatButtonModule } from '@angular/material/button';
import { MatDialogModule } from '@angular/material/dialog';
import { MatDividerModule } from '@angular/material/divider';
import { MatIconModule } from '@angular/material/icon';
import { MatTooltipModule } from '@angular/material/tooltip';
import { APIsService } from '../../../services/api.service';
import { LoaderComponent } from '../../side-panel/loader/loader.component';

@Component({
  changeDetection: ChangeDetectionStrategy.OnPush,
  selector: 'app-admin-contact',
  standalone: true,
  imports: [
    MatDialogModule,
    MatButtonModule,
    MatIconModule,
    FormsModule,
    MatTooltipModule,
    MatDividerModule,
    LoaderComponent,
  ],
  templateUrl: './admin-contact.component.html',
  styleUrl: './admin-contact.component.css',
})
export class AdminContactComponent implements OnInit {
  private readonly cdr = inject(ChangeDetectorRef);
  email = '';
  first_name = '';
  last_name = '';
  mobile = '';
  post = '';

  loading = false;

  constructor(private apiService: APIsService) {}

  async ngOnInit(): Promise<void> {
    await this.getContactDetails();
  }

  async getContactDetails() {
    this.loading = true;
    this.apiService.getAdminContactInfo().subscribe({
      next: (res: any) => {
        // this.logins = res;
        this.first_name = res[0].first_name;
        this.last_name = res[0].last_name;
        this.email = res[0].email;
        this.mobile = res[0].mobile;
        this.post = res[0].post;
        this.loading = false;

        this.cdr.markForCheck();
      },
      error: (err) => {
        this.loading = false;
        console.error('Failed to load contact details', err);
      },
    });
  }
}
</file>

<file path="src/app/components/dialogs/building-report/building-report.component.css">
/* ═══════════════════════════════════════════════════════════════
   Building Report Dialog  —  brr- prefix  —  Light theme
   ═══════════════════════════════════════════════════════════════ */

:host {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

/* ── Dialog Shell ── */
.brr-dialog {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  background: var(--surface-dialog);
  color: var(--text-primary);
  font-family: 'DM Sans', system-ui, sans-serif;
}

/* ── Header ── */
.brr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: var(--surface-header);
  border-bottom: 1px solid var(--border-default);
  border-radius: 12px 12px 0 0;
  flex-shrink: 0;
  cursor: grab;
}
.brr-header:active {
  cursor: grabbing;
}

.brr-header-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brr-header-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-on-header);
  flex-shrink: 0;
}

.brr-header-icon mat-icon {
  font-size: 20px;
  width: 20px;
  height: 20px;
}

.brr-title {
  margin: 0;
  font-size: 17px;
  font-weight: 700;
  color: var(--text-on-header);
  letter-spacing: 0.2px;
}

.brr-subtitle {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 1px;
  display: block;
  letter-spacing: 0.3px;
}

.brr-header-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.brr-icon-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  border-radius: 6px;
  color: var(--text-on-header);
  opacity: 0.7;
  cursor: pointer;
  transition: all 0.2s;
}

.brr-icon-btn:hover {
  background: rgba(255, 255, 255, 0.15);
  opacity: 1;
}

.brr-icon-btn mat-icon {
  font-size: 19px;
  width: 19px;
  height: 19px;
}

/* ── Identity Bar ── */
.brr-identity-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 20px;
  background: var(--surface-panel-alt);
  border-bottom: 1px solid var(--border-default);
  flex-shrink: 0;
  flex-wrap: wrap;
  gap: 8px;
}

.brr-identity-main {
  display: flex;
  align-items: center;
  gap: 10px;
}

.brr-building-id {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 600;
  color: var(--color-primary);
  letter-spacing: 0.3px;
}

.brr-status-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 10px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.brr-badge--active {
  background: rgba(40, 167, 69, 0.12);
  color: var(--color-success);
  border: 1px solid rgba(40, 167, 69, 0.25);
}

.brr-badge--pending {
  background: rgba(251, 191, 36, 0.12);
  color: var(--color-warning);
  border: 1px solid rgba(251, 191, 36, 0.25);
}

.brr-badge--info {
  background: rgba(119, 154, 184, 0.12);
  color: var(--color-primary);
  border: 1px solid rgba(119, 154, 184, 0.25);
}

.brr-badge--historic {
  background: rgba(108, 117, 125, 0.1);
  color: var(--text-secondary);
  border: 1px solid rgba(108, 117, 125, 0.2);
}

.brr-identity-meta {
  display: flex;
  align-items: center;
  gap: 16px;
}

.brr-meta-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: var(--text-secondary);
}

.brr-meta-item mat-icon {
  font-size: 14px;
  width: 14px;
  height: 14px;
}

/* ── Quick Stats Bar ── */
.brr-stats-bar {
  display: flex;
  align-items: center;
  background: var(--surface-panel-alt);
  border-bottom: 1px solid var(--border-default);
  overflow-x: auto;
  flex-shrink: 0;
}

.brr-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 20px;
  min-width: 100px;
}

.brr-stat-divider {
  width: 1px;
  height: 28px;
  background: var(--border-default);
  flex-shrink: 0;
}

.brr-stat-label {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--text-secondary);
  margin-bottom: 3px;
}

.brr-stat-value {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

/* ── Tab Bar ── */
.brr-tab-bar {
  display: flex;
  align-items: center;
  background: var(--surface-panel-alt);
  border-bottom: 1px solid var(--border-default);
  overflow-x: auto;
  flex-shrink: 0;
  padding: 0 8px;
}

.brr-tab-bar::-webkit-scrollbar {
  height: 2px;
}

.brr-tab-bar::-webkit-scrollbar-track {
  background: transparent;
}

.brr-tab-bar::-webkit-scrollbar-thumb {
  background: rgba(119, 154, 184, 0.3);
}

.brr-tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-secondary);
