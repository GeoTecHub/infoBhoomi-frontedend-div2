<file path="src/app/components/side-panel/side-panel.component.css">
/* ─── Sidebar Shell ─────────────────────────────────────── */
:host {
  display: block;
  height: 100%;
}

.sidebar {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: var(--surface-sidebar); /* UI-only change — was rgba(22,33,52,0.85) dark navy */
  border-right: 1px solid var(--border-default); /* UI-only change — was rgba(148,163,184,0.1) */
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  transition: width 0.2s ease;
  overflow: hidden;
}

.sidebar.collapsed {
  width: 30px;
}

/* ─── Resize Handle ─────────────────────────────────────── */
.resize-handle {
  position: absolute;
  right: -4px;
  top: 0;
  bottom: 0;
  width: 8px;
  cursor: col-resize;
  z-index: 20;
  background: transparent;
  transition: background 0.15s;
}

.resize-handle::after {
  content: '';
  position: absolute;
  right: 3px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: transparent;
  transition: background 0.15s;
}

.resize-handle:hover::after,
.resize-handle:active::after {
  background: var(
    --color-primary
  ); /* UI-only change — was var(--color-primary, rgba(79,70,229,0.8)) wrong fallback */
}

.resize-handle:hover,
.resize-handle:active {
  background: var(--surface-sidebar-hover); /* UI-only change — was rgba(79,70,229,0.15) indigo */
}

/* ─── Toggle Button ─────────────────────────────────────── */
.sidebar-toggle {
  position: absolute;
  right: -14px;
  top: 50%;
  transform: translateY(-50%);
  width: 24px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-panel); /* UI-only change — was rgba(30,41,59,0.9) dark slate */
  border: 1px solid var(--border-default); /* UI-only change — was rgba(148,163,184,0.2) */
  border-radius: 0 8px 8px 0;
  color: var(--text-secondary); /* UI-only change — was #94a3b8 (Tailwind slate-400) */
  cursor: pointer;
  z-index: 10;
  transition: all 0.2s ease;
  padding: 0;
}

.sidebar-toggle:hover {
  background: var(--surface-sidebar-hover); /* UI-only change — was rgba(79,70,229,0.2) indigo */
  color: var(--text-primary); /* UI-only change — was #e2e8f0 */
}

/* ─── Tab Bar ───────────────────────────────────────────── */
.sidebar-tab-bar {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border-default); /* UI-only change — was rgba(148,163,184,0.15) */
  background: var(
    --surface-sidebar-header
  ); /* UI-only change — was rgba(15,23,42,0.6) near-black */
  flex-shrink: 0;
}

.sidebar-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.3rem;
  padding: 0.6rem 0.25rem;
  border: none;
  background: transparent;
  color: var(--text-secondary); /* UI-only change — was #64748b (Tailwind slate-500) */
  font-size: 0.72rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
}

.sidebar-tab:hover:not(.disabled) {
  color: var(--text-primary); /* UI-only change — was #94a3b8 */
  background: var(--surface-sidebar-hover); /* UI-only change — was rgba(148,163,184,0.06) */
}

.sidebar-tab.active {
  color: var(--text-primary); /* UI-only change — was #e2e8f0 */
  border-bottom-color: var(
    --color-primary
  ); /* UI-only change — fixed wrong fallback #6366f1 indigo */
  background: var(--surface-sidebar-hover); /* UI-only change — was rgba(79,70,229,0.08) indigo */
}

.sidebar-tab.active svg {
  color: var(--color-primary); /* UI-only change — was #a5b4fc (Tailwind indigo-300) */
}

.sidebar-tab.disabled {
