});

// Style for selected features
const olSelectedStyle = new Style({
  stroke: new Stroke({ color: 'rgba(255, 0, 0, 0.9)', width: 3 }), // Red
  fill: new Fill({ color: 'rgba(255, 0, 0, 0.2)' }),
  image: new CircleStyle({
