<div class="material-header">
  <div class="header-content">
    <h2 class="header-title">Civilian</h2>
    <!-- <button class="close-btn">
    <mat-icon>close</mat-icon>
  </button> -->
  </div>
</div>

<mat-dialog-content>
  <mat-card class="custom-card">
    <mat-card-content>
      <div class="keyValueList">
        @if (data.path == 'full' && !show_all_inputs) {
          <div class="keyValueWrapper">
            <div class="keyValueWrapper__keyValue align-items-center">
              <div class="keyValue__key">Registration Type</div>
              <select class="keyValue__value" [(ngModel)]="civilian.party_registration_type">
                <option value="nic">National Identity Card</option>
                <option value="ps">Passport</option>
                <option value="dl">Driving License</option>
              </select>
            </div>
          </div>
        }

        @if (data.path == 'full' && !show_all_inputs && civilian.party_registration_type == 'nic') {
          <div class="keyValueWrapper">
            <div class="keyValueWrapper__keyValue align-items-center">
              <div class="keyValue__key">Number</div>
              <input
                class="keyValue__value"
                [(ngModel)]="civilian.registration_number"
                maxlength="12"
                (ngModelChange)="validateAndFormatNIC($event)"
                placeholder="Enter NIC"
                [ngClass]="{ 'is-invalid': !id_number_validation }"
              />
            </div>
          </div>
        }
        @if (!id_number_validation && civilian.party_registration_type == 'nic') {
          <div class="invalid-feedback">
            NIC must be 10 characters ending with 'V' or 'X', or 12 digits.
          </div>
        }

        @if (data.path == 'full' && !show_all_inputs && civilian.party_registration_type == 'ps') {
          <div class="keyValueWrapper">
            <div class="keyValueWrapper__keyValue align-items-center">
              <div class="keyValue__key">Number</div>
              <input
                class="keyValue__value"
                [(ngModel)]="civilian.registration_number"
                (ngModelChange)="validatePassportNumber()"
                placeholder="Enter Passport number"
                [ngClass]="{ 'is-invalid': !ps_number_validation }"
              />
            </div>
          </div>
        }
        @if (!ps_number_validation && civilian.party_registration_type == 'ps') {
          <div class="invalid-feedback">
            Invalid format. Must be one uppercase letter followed by seven digits.
          </div>
        }

        @if (data.path == 'full' && !show_all_inputs && civilian.party_registration_type == 'dl') {
          <div class="keyValueWrapper">
            <div class="keyValueWrapper__keyValue align-items-center">
              <div class="keyValue__key">Number</div>
              <input
                class="keyValue__value"
                [(ngModel)]="civilian.registration_number"
                (ngModelChange)="validateLicenseNumber()"
                placeholder="Enter License Number"
                [ngClass]="{ 'is-invalid': !license_number_validation }"
              />
            </div>
          </div>
        }
        @if (!license_number_validation && civilian.party_registration_type == 'dl') {
          <div class="invalid-feedback">
            Invalid format. Must be one uppercase letter followed by seven digits.
          </div>
        }

        @if (data.path == 'full') {
          <div class="container">
            @if (registed_number_searched && !party_already_existing) {
              <button mat-icon-button matSuffix (click)="showCreateInputs()" class="primary-bg-btn">
                Add New +
              </button>
            }
            &nbsp; &nbsp;
            @if (data.path == 'full' && !show_all_inputs) {
              <button
                mat-icon-button
                matSuffix
                (click)="getCivilianUserData()"
                class="primary-bg-btn"
              >
                <mat-icon>search</mat-icon> Search
              </button>
            }
          </div>
        }
        @if (this.data.path == 'full' && !show_all_inputs) {
          <hr class="hr-divider" />
        }
        @if (party_already_existing && !show_all_inputs && data.path == 'full') {
          <div>
            <!-- <mat-card-title class="card-main-title">
                  Civilian Information
                </mat-card-title> -->
            <div class="label-value-list">
              <div class="label-value-item">
                <span class="label"> Identification Type:</span>
                @if (party_identification.ext_pid_type == 'nic') {
                  <span class="value">National Identity Card</span>
                }
                @if (party_identification.ext_pid_type == 'ps') {
                  <span class="value">Passport</span>
                }
                @if (party_identification.ext_pid_type == 'dl') {
                  <span class="value">Driving License</span>
                }
                @if (party_identification.ext_pid_type == 'oth') {
                  <span class="value">Other</span>
                }
              </div>
              <div class="label-value-item">
                <span class="label">Number:</span>
                <span class="value">{{ party_identification.ext_pid }}</span>
              </div>
              <div class="label-value-item">
                <span class="label"> Name:</span>
                <span class="value">{{ party_identification.party_full_name }}</span>
              </div>
              <div class="label-value-item">
                <span class="label">Primary Telephone:</span>
                <span class="value">{{ party_identification.specific_tp }}</span>
              </div>
              <div class="label-value-item">
                <span class="label"> Address:</span>
                <span class="value">{{ party_identification.pmt_address }}</span>
              </div>
            </div>
            @if (civilian_data__array.length != 0) {
              <div class="container">
                <a (click)="showPartyAllInputs()" class="link-text">View More...</a>
              </div>
            }
          </div>
        }
        @if (show_all_inputs || data.path == 'create_form') {
          <div class="show_all_inputs">
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Registration Type</div>
                <select
                  class="keyValue__value"
                  [(ngModel)]="party_identification.ext_pid_type"
                  disabled
                >
                  <option value="" disabled selected>Select Party Sub Type</option>
                  <option value="br">Business Registration</option>
                  <option value="nic">National Identity Card</option>
                  <option value="ps">Passport</option>
                  <option value="dl">Driving License</option>
                  <option value="ua">Under Age</option>
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Number</div>
                <input
                  type="text"
                  class="keyValue__value"
                  readonly
                  [(ngModel)]="party_identification.ext_pid"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">
                  Name
                  @if (canEditTrue()) {
                    <span class="text-danger">*</span>
                  }
                </div>
                <input
                  type="text"
                  class="keyValue__value"
                  [readonly]="canEditTrue()"
                  [(ngModel)]="party_identification.party_name"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">
                  Full Name
                  @if (canEditTrue()) {
                    <span class="text-danger">*</span>
                  }
                </div>
                <input
                  type="text"
                  class="keyValue__value"
                  [readonly]="canEditTrue()"
                  [(ngModel)]="party_identification.party_full_name"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Party Type</div>
                <input
                  type="text"
                  class="keyValue__value"
                  value="Civilian"
                  [(ngModel)]="party_identification.sl_party_type"
                  readonly
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Telephone <span class="text-danger">*</span></div>
                <input
                  type="number"
                  class="keyValue__value"
                  [readonly]="canEditTrue()"
                  type="tel"
                  maxlength="10"
                  pattern="0\d{9}"
                  (keypress)="allowOnlyNumbers($event)"
                  (input)="limitInputLength($event)"
                  (change)="validationsCheck($event, 'second_number')"
                  [(ngModel)]="party_identification.specific_tp"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Other Telephone</div>
                <input
                  class="keyValue__value"
                  type="tel"
                  maxlength="10"
                  pattern="0\d{9}"
                  (keypress)="allowOnlyNumbers($event)"
                  (input)="limitInputLength($event)"
                  (change)="validationsCheck($event, 'mobile_number')"
                  [(ngModel)]="party_identification.tp"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Address <span class="text-danger">*</span></div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.pmt_address"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Email</div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.email"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Date Of Birth</div>
                <input
                  type="date"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.date_of_birth"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Gender</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.gender">
                  <option value="" disabled selected>Select Gender Type</option>
                  @for (option of gender_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Education Level</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.edu">
                  <option value="" disabled selected>Select Education Level</option>
                  @for (option of education_leval_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Married Status</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.married_status">
                  <option value="" disabled selected>Select Married Status</option>
                  @for (option of married_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Race</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.race">
                  <option value="" disabled selected>Select Race</option>
                  @for (option of race_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Religion</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.religion">
                  <option value="" disabled selected>Select Religion</option>
                  @for (option of religion_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Helth Types</div>
                <select class="keyValue__value" [(ngModel)]="party_identification.health_status">
                  <option value="" disabled selected>Select Helth Type</option>
                  @for (option of helth_types_array; track option) {
                    <option [value]="option.name">
                      {{ option.name }}
                    </option>
                  }
                </select>
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue align-items-center">
                <div class="keyValue__key">Remark</div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.remark"
                />
              </div>
            </div>
            <hr class="hr-divider" />
            @if (this.data.path == 'full' && show_all_inputs) {
              <div class="keyValueList">
                @if (show_all_inputs) {
                  <div>
                    <mat-card-title class="card-main-title"
                      >Other Registration Information</mat-card-title
                    >
                  </div>
                }
                @if (show_all_inputs || this.data.path == 'full') {
                  <div class="show_all_inputs" style="background-color: #fff">
                    <div class="row">
                      <div class="col-5">
                        <div class="keyValueWrapper">
                          <div class="keyValueWrapper__keyValue align-items-center">
                            <div class="keyValue__key" style="margin-top: 5px; margin-left: 7px">
                              Type
                            </div>
                            <select
                              class="keyValue__value"
                              (ngModelChange)="partyTypeChange()"
                              [(ngModel)]="civilian_party.party_registration_type"
                            >
                              <option value="" disabled>Select Reg. Type</option>
                              @if (civilian.party_registration_type != 'nic') {
                                <option value="nic">National Identity Card</option>
                              }
                              @if (civilian.party_registration_type != 'ps') {
                                <option value="ps">Passport</option>
                              }
                              @if (civilian.party_registration_type != 'dl') {
                                <option value="dl">Driving License</option>
                              }
                            </select>
                          </div>
                        </div>
                      </div>
                      <div class="col-5">
                        <div class="keyValueWrapper">
                          <div
                            class="keyValueWrapper__keyValue input-button-wrapper align-items-center"
                          >
                            <div class="keyValue__key" style="margin-top: 5px; margin-left: 7px">
                              Number
                            </div>
                            @if (civilian_party.party_registration_type == 'nic') {
                              <input
                                class="keyValue__value"
                                [(ngModel)]="civilian_party.registration_number"
                                maxlength="12"
                                (ngModelChange)="validateAndFormatNIC($event)"
                                placeholder="Enter NIC"
                                [ngClass]="{ 'is-invalid': !id_number_validation }"
                              />
                            }
                            @if (civilian_party.party_registration_type == 'ps') {
                              <input
                                class="keyValue__value"
                                [(ngModel)]="civilian_party.registration_number"
                                (ngModelChange)="validatePassportNumber()"
                                placeholder="Enter Passport number"
                                [ngClass]="{ 'is-invalid': !ps_number_validation }"
                              />
                            }
                            @if (civilian_party.party_registration_type == '') {
                              <input class="keyValue__value" placeholder="Enter Reg. No." />
                            }
                            @if (civilian_party.party_registration_type == 'dl') {
                              <input
                                class="keyValue__value"
                                [(ngModel)]="civilian_party.registration_number"
                                (ngModelChange)="validateLicenseNumber()"
                                placeholder="Enter License Number"
                                [ngClass]="{ 'is-invalid': !license_number_validation }"
                              />
                            }
                          </div>
                        </div>
                        @if (
                          !license_number_validation ||
                          !ps_number_validation ||
                          !id_number_validation
                        ) {
                          <span class="text-danger" style="margin-left: 155px">Invalid format</span>
                        }
                      </div>
                      @if (this.data.path == 'full') {
                        <div class="col-2">
                          <button
                            class="primary-sm-btn-select-custom"
                            (click)="addRegistrationTypes()"
                          >
                            Add+
                          </button>
                        </div>
                      }
                    </div>
                  </div>
                }
              </div>
            }
            <br />
            @if (registration_array.length > 0 || this.data.path == 'full') {
              <div>
                <div class="card">
                  <div class="card-content">
                    @for (item of registration_array; track item; let i = $index) {
                      <div>
                        <div class="row other-reg-cards">
                          <div class="col-5">
                            @if (item.split('|')[0] == 'nic') {
                              <span> National Identity Card </span>
                            }
                            @if (item.split('|')[0] == 'ps') {
                              <span> Passport </span>
                            }
                            @if (item.split('|')[0] == 'dl') {
                              <span> Driving License </span>
                            }
                          </div>
                          <div class="col-5">
                            {{ item.split('|')[1] }}
                            <!-- Extract "Registration Number:Number" -->
                          </div>
                          <div class="col-2">
                            <button mat-icon-button class="delete-btn" (click)="removeEntry(i)">
                              <i class="fa fa-trash"></i>
                            </button>
                          </div>
                        </div>
                      </div>
                    }
                  </div>
                </div>
              </div>
            }
            @if ((show_all_inputs && this.data.path == 'full') || this.data.path == 'create_form') {
              <div class="container">
                <button mat-icon-button matSuffix (click)="SubmitAll()" class="primary-bg-btn">
                  <mat-icon>save</mat-icon> Save
                </button>
              </div>
            }
          </div>
        }
      </div>
    </mat-card-content>
  </mat-card>
</mat-dialog-content>
<mat-dialog-actions align="end">
  <!-- *ngIf="civilian_data__array.length != 0" -->
  <div class="container">
    &nbsp;
    <button
      mat-icon-button
      matSuffix
      [disabled]="!civilian"
      (click)="closeDialog()"
      class="primary-bg-btn"
    >
      <mat-icon>close</mat-icon> Close</button
    >&nbsp;&nbsp;&nbsp;
    @if (data.path == 'full') {
      <button mat-icon-button matSuffix (click)="addCivilian()" class="primary-bg-btn">
        <mat-icon>add</mat-icon> Select
      </button>
    }
    @if (data.path == 'create_form') {
      <button
        mat-icon-button
        matSuffix
        [disabled]="!data_submitted"
        (click)="addData()"
        class="primary-bg-btn"
      >
        Add &nbsp;<i class="fa fa-plus plus-btn"></i>
      </button>
    }
  </div>
</mat-dialog-actions>
</file>

<file path="src/app/components/dialogs/company/company.component.css">
.mat-dialog-container {
  border-radius: 15px !important;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
}

/* DIALOG HEADER */
.material-header {
  background-color: #779ab8;
  /* Material primary color */
  color: white;
  padding: 10px 15px;
  border-radius: 5px;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* Align title left and button right */
}

.header-title {
  margin: 0;
  font-size: 20px;
}

label {
  font-size: 12px;
  font-weight: bold;
  opacity: 0.7;
  margin-top: -10px;
}

.sub-field {
  padding-left: 10px;
}

/* ********************footer-section******************************** */

.loading-toast {
  position: absolute;
  height: calc(100% - 90px);
  width: 300px;
}

app-collapsible .collapsible-content {
  pointer-events: none;
}

.label-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.keyValueList {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.keyValueWrapper {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 5px;
  border-radius: 5px;
}

.keyValueWrapper__keyValue {
  display: flex;
  justify-content: space-between;
  width: 100%;
}

.keyValueWrapper__keyValue select {
  width: 100%;
}

.keyValue__key {
  font-weight: bold;
  color: var(--color-secondary-d2, #555);
  flex: 1;
  font-size: 12px;
  line-height: 14px;
}

.keyValue__value {
  color: var(--color-secondary-d1, #333);
  margin-left: 15px;
  flex: 2;
  font-size: 12px;
  line-height: 14px;
}

select {
  border-color: var(--color-secondary-l2, #ccc);
  border-radius: 5px;
  border: 1px solid var(--color-secondary-l2, #ccc);
  background-color: var(--color-white, #fff);
  transition: border-color 0.2s ease-in-out;
  padding: 5px;
  min-width: 100px;
}

select:focus {
  outline: none;
  border-color: var(--color-primary, #007bff);
}

select::placeholder {
  color: var(--color-secondary-l2, #ccc);
  opacity: 0.7;
}

.keyValue__value {
  border: 1px solid var(--color-secondary-l2);
  border-radius: 5px;
  padding: 5px;
  min-width: 100px;
  width: 100%;
}

.keyValue__value:focus {
  outline: none;
  border-color: var(--color-primary);
}

.keyValueWrapper {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 5px;
}

body {
  font-family: 'Calibri', sans-serif;
}

.card-container {
  width: 100%;
  display: flex;
  justify-content: space-between;
  /* Ensures spacing between cards */
  gap: 15px;
  /* Adds spacing between cards */
}

.custom-card {
  flex: 1;
  /* Ensures each card takes equal space */
  max-width: 100%;
  /* Limits each card to 50% of the parent width */
  margin-bottom: 10px;
  background-color: white;
}

.card-main-title {
  font-weight: bold;
  color: var(--color-secondary-d2, #555);
  flex: 1;
  font-size: 14px;
  line-height: 14px;
  margin-bottom: 5px;
}

.card-sub-title {
  font-size: 12px;
  padding: 10px;
  text-align: center;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  /* 2 equal columns */
  gap: 16px;
  /* Space between columns */
}

mat-form-field {
  width: 100%;
  /* Ensure the form field takes up full width of its grid cell */
}

.label {
  margin-right: 8px;
  /* Space between the label and the value */
}

.row-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* Pushes delete button to the right */
  gap: 10px;
}

.spacer {
  flex-grow: 1;
  /* Pushes the delete button to the row end */
}

/* Style the overall container for the title and buttons */
.d-flex {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px;
}

.control-button {
  display: flex;
  gap: 10px;
  /* Space between the buttons */
}

/* Style the title */
.mat-dialog-title {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 600;
}

/* Style for individual buttons */
button.mat-button {
  border: 1px solid #007bff;
  /* Border color */
  color: #007bff;
  /* Text color */
  background-color: transparent;
  /* Transparent background */
  border-radius: 4px;
  /* Rounded corners */
  padding: 5px 10px;
  /* Padding for the button */
  display: flex;
  align-items: center;
  justify-content: center;
}

button.mat-button:hover {
  background-color: #007bff;
  /* Hover background color */
  color: white;
  /* Hover text color */
}

/* Style for icons inside buttons */
button.mat-button i {
  font-size: 16px;
  /* Icon size */
  margin: 0;
  /* Remove any margin around the icon */
}

/* Optional: Add additional styles for the outline */
.btn-outline-primary {
  border: 1px solid #007bff;
}

.btn-sm {
  font-size: 12px;
}

/* Optional: Style the close button */
button.mat-dialog-close {
  background-color: transparent;
  /* Transparent background */
  color: #dc3545;
  /* Red color for close */
}

.container {
  display: flex;
  justify-content: flex-end;
  /* Align button to the right */
}

.search-btn {
  border-radius: 20px;
  border: none;
  width: 100px;
  background-color: #779ab8;
  color: white;
  display: flex;
  margin-top: 10px;
  align-items: center;
  justify-content: center;
  /* border-radius: 4px; */
  padding: 5px;
}

.search-btn mat-icon {
  margin-right: 5px;
  /* Space between the icon and the text */
}

.search-btn:hover {
  background-color: #779ab8;
}

/* Container for the entire list */
.label-value-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  /* Space between items */
  /* max-width: 300px;  */
  margin: 0 auto;
  /* Centering the list */
}

/* Individual label-value item */
.label-value-item {
  display: flex;
  justify-content: space-between;
  /* Align label and value on opposite ends */
  padding: 5px 0;
  /* Space between label-value pair */
  border-bottom: 1px solid #ddd;
  /* Optional: add a separator line between items */
}

/* Style for the label */
.label {
  font-weight: 500;
  color: #333;
  width: 180px;
}

/* Style for the value */
.value {
  color: #555;
  text-align: right;
  /* Align value to the right */
  flex-grow: 1;
  /* Allow value to take up remaining space */
}

.close-btn:hover {
  color: red;
}

.card .inline {
  margin: 0;
  flex-grow: 1;
  /* Allow text to expand */
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
}

.delete-btn {
  background-color: red !important;
  color: white !important;
  border-radius: 50%;
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border: none;
}
</file>

<file path="src/app/components/dialogs/company/company.component.html">
<div class="material-header">
  <div class="header-content">
    <h2 class="header-title">Company</h2>
  </div>
</div>

<mat-dialog-content>
  <mat-card class="custom-card">
    <mat-card-content>
      <div class="keyValueList">
        @if (data.path == 'full') {
          <div class="keyValueWrapper">
            <div class="keyValueWrapper__keyValue">
              <div class="keyValue__key">Registration Number</div>
              <input
                type="text"
                class="keyValue__value"
                [(ngModel)]="company_info.registration_number"
              />
            </div>
          </div>
        }
        @if (data.path == 'full') {
          <div class="container">
            <button
              mat-icon-button
              matSuffix
              [disabled]="!company_info.registration_number"
              (click)="getCompanyData()"
              class="search-btn"
            >
              <mat-icon>search</mat-icon> Search
            </button>
          </div>
        }
        @if (data.path == 'full') {
          <hr class="hr-divider" />
        }
        @if (party_already_existing && data.path == 'full' && !edit_or_create_form) {
          <div>
            <mat-card-title class="card-main-title"> Existing Party Information </mat-card-title>
            <!-- <hr class="hr-divider"> -->
            <br />
            <div class="label-value-list">
              <div class="label-value-item">
                <span class="label">Party Identification Type:</span>
                <span class="value">{{ party_identification.ext_pid_type }}</span>
              </div>
              <div class="label-value-item">
                <span class="label">Party NIC:</span>
                <span class="value">{{ party_identification.ext_pid }}</span>
              </div>
              <div class="label-value-item">
                <span class="label">Party Name:</span>
                <span class="value">{{ party_identification.party_name }}</span>
              </div>
              <div class="label-value-item">
                <span class="label">Party Telephone:</span>
                <span class="value">{{ party_identification.tp }}</span>
              </div>
              <div class="label-value-item">
                <span class="label">Party Address:</span>
                <span class="value">{{ party_identification.pmt_address }}</span>
              </div>
            </div>
          </div>
        }
        @if (
          (edit_or_create_form && data.path == 'full') ||
          data_not_found == true ||
          data.path == 'create_form'
        ) {
          <div class="show_all_inputs">
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Registration Number</div>
                <input
                  type="text"
                  class="keyValue__value"
                  readonly
                  [(ngModel)]="party_identification.ext_pid"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Party Full Name <span class="text-danger">*</span></div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.party_full_name"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Party Name <span class="text-danger">*</span></div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.party_name"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Telephone</div>
                <input
                  class="keyValue__value"
                  type="tel"
                  maxlength="10"
                  pattern="0\d{9}"
                  (keypress)="allowOnlyNumbers($event)"
                  (input)="limitInputLength($event)"
                  (change)="validationsCheck($event, 'mobile_number')"
                  [(ngModel)]="party_identification.tp"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">
                  Specific Telephone <span class="text-danger">*</span>
                </div>
                <input
                  class="keyValue__value"
                  type="tel"
                  maxlength="10"
                  pattern="0\d{9}"
                  (keypress)="allowOnlyNumbers($event)"
                  (input)="limitInputLength($event)"
                  (change)="validationsCheck($event, 'mobile_number')"
                  [(ngModel)]="party_identification.specific_tp"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Party Address <span class="text-danger">*</span></div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.pmt_address"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Company Registration Date</div>
                <input
                  type="date"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.date_of_birth"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Email</div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.email"
                />
              </div>
            </div>
            <div class="keyValueWrapper">
              <div class="keyValueWrapper__keyValue">
                <div class="keyValue__key">Remarks</div>
                <input
                  type="text"
                  class="keyValue__value"
                  [(ngModel)]="party_identification.remark"
                />
              </div>
            </div>
          </div>
        }
      </div>
      @if (party_already_existing && data.path == 'full' && !edit_or_create_form) {
        <div class="container">
          <button mat-icon-button matSuffix (click)="showPartyAllInputs()" class="search-btn">
            <mat-icon>edit</mat-icon> Edit
          </button>
        </div>
      }
      @if (
        (data_not_found == true && this.data.path == 'full') || this.data.path == 'create_form'
      ) {
        <div class="container">
          <button mat-icon-button matSuffix (click)="SubmitAll()" class="search-btn">
            <mat-icon>save</mat-icon> Save
          </button>
        </div>
      }
    </mat-card-content>
  </mat-card>
</mat-dialog-content>
<mat-dialog-actions align="end">
  <!-- *ngIf="civilian_data__array.length != 0" -->
  <div class="container">
    &nbsp;
    <button mat-icon-button matSuffix (click)="closeDialog()" class="search-btn">
      <mat-icon>close</mat-icon> Close</button
    >&nbsp;&nbsp;&nbsp;
    @if (data.path == 'full') {
      <button mat-icon-button matSuffix (click)="addCompany()" class="search-btn">
        Add &nbsp;<i class="fa fa-plus plus-btn"></i>
      </button>
    }
    &nbsp;&nbsp;&nbsp;
    @if (data.path == 'create_form') {
      <button mat-icon-button matSuffix (click)="addData()" class="search-btn">
        Add &nbsp;<i class="fa fa-plus plus-btn"></i>
      </button>
    }
  </div>
</mat-dialog-actions>
