  height: 100%;
}

.gqc-parcel {
  fill: #132744;
  stroke: #1e3a5f;
  stroke-width: 0.25;
  opacity: 0.45;
  transition: all 0.6s ease;
}

.gqc-map-scale {
  position: absolute;
  bottom: 10px;
  left: 10px;
  display: flex;
  align-items: center;
  gap: 5px;
}

.gqc-scale-bar {
  width: 50px;
  height: 3px;
  background: #6ba3d6;
  border-radius: 2px;
  position: relative;
}

.gqc-scale-bar::before,
.gqc-scale-bar::after {
  content: '';
  position: absolute;
  top: -2px;
  width: 1px;
  height: 7px;
  background: #6ba3d6;
}

.gqc-scale-bar::before {
  left: 0;
}

.gqc-scale-bar::after {
  right: 0;
}

.gqc-map-scale span {
  color: #6ba3d6;
  font-size: 10px;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
}

.gqc-map-coords {
  position: absolute;
  bottom: 10px;
  right: 10px;
  color: #6a9abc;
  font-size: 10px;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
}

.gqc-map-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 22, 40, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(2px);
}

.gqc-map-overlay-text {
  color: #4a9eff;
  font-size: 13px;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  animation: gqc-pulse 1.5s ease infinite;
}

/* ═══ Empty State ═══ */

.gqc-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4a7a9b;
  text-align: center;
  padding: 40px;
}

.gqc-empty-icon {
  font-size: 48px !important;
  width: 48px !important;
  height: 48px !important;
  opacity: 0.4;
  color: #6a9abc;
  margin-bottom: 16px;
}

.gqc-empty-title {
  font-size: 17px;
  font-weight: 600;
  color: #5a8aac;
  margin-bottom: 8px;
}

.gqc-empty-desc {
  font-size: 13px;
  color: #4a7a9b;
  max-width: 340px;
  line-height: 1.6;
}

.gqc-empty-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 20px;
}

.gqc-tag {
  padding: 5px 13px;
  border-radius: 16px;
  background: #0d1f33;
  border: 1px solid #1a2d4a;
  font-size: 12px;
  color: #6a9abc;
}

/* ═══ Spinner ═══ */

.gqc-spinner {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: gqc-spin 0.6s linear infinite;
}

/* ═══ Scrollbar ═══ */

.gqc-sidebar::-webkit-scrollbar,
.gqc-query-list::-webkit-scrollbar,
.gqc-param-section::-webkit-scrollbar {
  width: 5px;
}

.gqc-sidebar::-webkit-scrollbar-track,
.gqc-query-list::-webkit-scrollbar-track,
.gqc-param-section::-webkit-scrollbar-track {
  background: transparent;
}

.gqc-sidebar::-webkit-scrollbar-thumb,
.gqc-query-list::-webkit-scrollbar-thumb,
.gqc-param-section::-webkit-scrollbar-thumb {
  background: #1e3a5f;
  border-radius: 3px;
}

/* ═══ Animations ═══ */

@keyframes gqc-spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes gqc-pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ═══ Responsive ═══ */

@media (max-width: 900px) {
  .gqc-sidebar {
    width: 160px;
    min-width: 160px;
  }

  .gqc-query-list {
    width: 200px;
    min-width: 200px;
  }

  .gqc-badge--muted {
    display: none;
  }
}

@media (max-width: 700px) {
  .gqc-sidebar {
    display: none;
  }

  .gqc-query-list {
    width: 180px;
    min-width: 180px;
  }
}

/* ═══ Minimized State ═══ */

.gqc-dialog--minimized {
  height: auto;
}

/* ═══ Highlight Strip ═══ */

.gqc-highlight-strip {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  background: linear-gradient(135deg, #0a1628, #0d2a18);
  border: 1px solid rgba(46, 204, 113, 0.3);
  border-radius: 0;
  position: relative;
  overflow: hidden;
}

.gqc-hl-pulse {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(46, 204, 113, 0.05), transparent);
  animation: gqc-hl-sweep 2.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes gqc-hl-sweep {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.gqc-hl-icon {
  font-size: 22px !important;
  width: 22px !important;
  height: 22px !important;
  color: #2ecc71;
  flex-shrink: 0;
  animation: gqc-pulse 1.8s ease-in-out infinite;
}

.gqc-hl-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
  min-width: 0;
}

.gqc-hl-title {
  font-size: 13px;
  font-weight: 700;
  color: #e8f0f8;
  white-space: nowrap;
}

.gqc-hl-hint {
  font-size: 11px;
  color: #5a8aac;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  white-space: nowrap;
}

.gqc-hl-hint kbd {
  background: #1a2d4a;
  border: 1px solid #2a4a6a;
  border-radius: 3px;
  padding: 1px 5px;
  font-family: inherit;
  font-size: 10px;
  color: #8abbe6;
}

.gqc-restore-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 14px;
  border-radius: 6px;
  background: rgba(46, 204, 113, 0.12);
  border: 1px solid rgba(46, 204, 113, 0.35);
  color: #2ecc71;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}

.gqc-restore-btn mat-icon {
  font-size: 15px;
  width: 15px;
  height: 15px;
}

.gqc-restore-btn:hover {
  background: rgba(46, 204, 113, 0.22);
  border-color: rgba(46, 204, 113, 0.6);
}

/* ═══ Highlight / Action Button (in results bar) ═══ */

.gqc-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 12px;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 0.2s;
  white-space: nowrap;
}

.gqc-action-btn mat-icon {
  font-size: 14px;
  width: 14px;
  height: 14px;
}

.gqc-action-btn--highlight {
  background: rgba(46, 204, 113, 0.15);
  border: 1px solid rgba(46, 204, 113, 0.4);
  color: #2ecc71;
}

.gqc-action-btn--highlight:hover:not(:disabled) {
  background: rgba(46, 204, 113, 0.25);
  border-color: rgba(46, 204, 113, 0.65);
}

.gqc-action-btn--highlight:disabled {
  opacity: 0.4;
  cursor: default;
}

/* ═══ Query Card Header (name + preview badge) ═══ */

.gqc-query-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 3px;
}

.gqc-preview-badge {
  font-size: 9px;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  padding: 2px 6px;
  border-radius: 10px;
  background: rgba(230, 126, 34, 0.15);
  border: 1px solid rgba(230, 126, 34, 0.4);
  color: #e67e22;
  flex-shrink: 0;
  white-space: nowrap;
}

/* ═══ Preview-Only Notice ═══ */

.gqc-preview-notice {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-top: 14px;
  padding: 10px 14px;
  border-radius: 8px;
  background: rgba(230, 126, 34, 0.08);
  border: 1px solid rgba(230, 126, 34, 0.25);
  color: #c9884e;
  font-size: 12px;
  line-height: 1.5;
}

.gqc-preview-notice mat-icon {
  font-size: 16px;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  margin-top: 1px;
  color: #e67e22;
}

/* ═══ Results Table ═══ */

.gqc-results-table-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: #080f1c;
}

.gqc-results-table-header {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  font-size: 11px;
  color: #5a8aac;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  border-bottom: 1px solid #1a2d4a;
  background: #0a1628;
  flex-shrink: 0;
}

.gqc-results-table-header mat-icon {
  font-size: 15px;
  width: 15px;
  height: 15px;
}

.gqc-results-table-container {
  flex: 1;
  overflow: auto;
}

.gqc-results-table-container::-webkit-scrollbar {
  width: 5px;
  height: 5px;
}

.gqc-results-table-container::-webkit-scrollbar-track {
  background: transparent;
}

.gqc-results-table-container::-webkit-scrollbar-thumb {
  background: #1e3a5f;
  border-radius: 3px;
}

.gqc-results-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  white-space: nowrap;
}

.gqc-results-table thead {
  position: sticky;
  top: 0;
  z-index: 1;
  background: #0d1b2a;
}

.gqc-results-table th {
  padding: 8px 14px;
  text-align: left;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: #5a8aac;
  border-bottom: 1px solid #1a2d4a;
  font-weight: 600;
}

.gqc-results-table td {
  padding: 7px 14px;
  color: #a0c4dd;
  border-bottom: 1px solid #0f1e30;
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.gqc-results-table tbody tr:hover td {
  background: rgba(74, 158, 255, 0.05);
  color: #c8e0f4;
}

.gqc-no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120px;
  gap: 8px;
  color: #4a7a9b;
  font-size: 13px;
}

.gqc-no-results mat-icon {
  font-size: 28px;
  width: 28px;
  height: 28px;
  opacity: 0.5;
}
