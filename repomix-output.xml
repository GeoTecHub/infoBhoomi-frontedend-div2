          <button mat-raised-button color="primary" (click)="startSelectionProcess()">
            <mat-icon>mouse</mat-icon>
            <span>Select Objects on Map</span>
          </button>
        }
        <!-- The STOP button -->
        @if (isSelectingForExport) {
          <button mat-raised-button color="accent" (click)="stopSelectionProcess()">
            <mat-icon>check_circle</mat-icon>
            <span>Done Selecting</span>
          </button>
        }
        <!-- Banner shown DURING selection -->
        @if (isSelectingForExport) {
          <div class="selection-banner">
