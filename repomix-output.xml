<aside class="sidebar" [class.collapsed]="isSidebarClosed()" [class.extended]="extendWidth">
  <!-- Resize Handle -->
  <div class="resize-handle" (mousedown)="onResizeStart($event)"></div>

  <!-- Toggle Button -->
  <button
    class="sidebar-toggle"
    (click)="toggleSidebar()"
    [attr.aria-label]="isSidebarClosed() ? 'Open sidebar' : 'Close sidebar'"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      @if (isSidebarClosed()) {
        <polyline points="9 18 15 12 9 6" />
      } @else {
        <polyline points="15 18 9 12 15 6" />
      }
    </svg>
  </button>

  @if (!isSidebarClosed()) {
    <!-- Tab Bar -->
    <div class="sidebar-tab-bar">
      <!-- Home -->
      <button
        class="sidebar-tab"
        [class.active]="activeSidebarTab() === 'home'"
        (click)="switchTab('home')"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M3 12l9-9 9 9" />
          <path d="M5 10v10a1 1 0 0 0 1 1h3v-6h6v6h3a1 1 0 0 0 1-1V10" />
        </svg>
        <span>Home</span>
      </button>

      <!-- Land -->
      <button
        class="sidebar-tab"
        [class.active]="activeSidebarTab() === 'land'"
        (click)="switchTab('land')"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span>Land</span>
      </button>

      <!-- Building -->
      <button
        class="sidebar-tab"
        [class.active]="activeSidebarTab() === 'building'"
        (click)="switchTab('building')"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M3 21h18" />
          <path d="M5 21V7l7-4 7 4v14" />
          <rect x="9" y="9" width="2" height="2" />
          <rect x="13" y="9" width="2" height="2" />
          <rect x="9" y="13" width="2" height="2" />
          <rect x="13" y="13" width="2" height="2" />
        </svg>
        <span>Building</span>
      </button>

      <!-- Report Button -->
      <button
        class="sidebar-tab sidebar-tab--report"
        [disabled]="!currentLandParcelInfo() && !currentBuildingInfo()"
        (click)="openGenerateReport()"
        title="Generate Report"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="16" y1="13" x2="8" y2="13" />
          <line x1="16" y1="17" x2="8" y2="17" />
          <polyline points="10 9 9 9 8 9" />
        </svg>
        <span>Report</span>
      </button>
    </div>

    <!-- Tab Content -->
    @if (activeSidebarTab() === 'home') {
      <div class="sidebar-tab-content">
        <app-home-tab></app-home-tab>
      </div>
    }

    @if (activeSidebarTab() === 'land') {
      <div class="sidebar-tab-content">
        <app-land-info-panel
          [parcelInfo]="currentLandParcelInfo()"
          [sectionPerms]="sectionPerms()"
          (rrrChanged)="onLandRRRChanged($event)"
          (identificationChanged)="onLandIdentificationChanged($event)"
          (spatialChanged)="onLandSpatialChanged($event)"
          (physicalChanged)="onLandPhysicalChanged($event)"
          (zoningChanged)="onLandZoningChanged($event)"
          (valuationChanged)="onLandValuationChanged($event)"
          (relationshipsChanged)="onLandRelationshipsChanged($event)"
          (metadataChanged)="onLandMetadataChanged($event)"
          (saveParcelRequested)="onSaveLandParcel($event)"
          (newParcelRequested)="onNewParcelRequested($event)"
        ></app-land-info-panel>
      </div>
    }

    @if (activeSidebarTab() === 'building') {
      <div class="sidebar-tab-content">
        <app-building-info-panel
          [buildingInfo]="currentBuildingInfo()"
          [modelLoaded]="buildingModelLoaded()"
          [sectionPerms]="sectionPerms()"
          (rrrChanged)="onBuildingRRRChanged($event)"
          (summaryChanged)="onBuildingSummaryChanged($event)"
          (unitsChanged)="onBuildingUnitsChanged($event)"
          (spatialChanged)="onBuildingSpatialChanged($event)"
          (physicalChanged)="onBuildingPhysicalChanged($event)"
          (utilitiesChanged)="onBuildingUtilitiesChanged($event)"
          (relationshipsChanged)="onBuildingRelationshipsChanged($event)"
          (metadataChanged)="onBuildingMetadataChanged($event)"
          (saveBuildingRequested)="onSaveBuildingInfo($event)"
        ></app-building-info-panel>
      </div>
    }
  }
</aside>
