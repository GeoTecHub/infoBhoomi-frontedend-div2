/* ── Content ── */
.brr-content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 0 !important;
  max-height: none !important;
  background: var(--surface-dialog);
}

.brr-content::-webkit-scrollbar {
  width: 5px;
}

.brr-content::-webkit-scrollbar-track {
  background: transparent;
}

.brr-content::-webkit-scrollbar-thumb {
  background: rgba(119, 154, 184, 0.3);
  border-radius: 3px;
}

.brr-tab-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── Sections ── */
.brr-section {
  background: var(--surface-panel);
  border: 1px solid var(--border-default);
  border-radius: 10px;
  padding: 18px 20px;
}

.brr-section-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border-default);
}

.brr-section-icon {
