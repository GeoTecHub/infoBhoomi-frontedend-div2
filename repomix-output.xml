  border-collapse: separate;
  border-spacing: 0;
  width: 100%;
}

.project-table tbody tr {
  border: 1px solid #ccc;
  margin-bottom: 10px;
  background-color: white;
  transition: background-color 0.3s;
}

.project-table tbody tr td {
