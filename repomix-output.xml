<file path="src/app/admin/organizations/organization-area-edit/organization-area-edit.component.html">
<div class="header-container">
  <app-admin-header></app-admin-header>
</div>

<div class="admin-main-body">
  <div class="side-panel-container">
    <app-admin-side-bar></app-admin-side-bar>
  </div>

  <div class="tab-container">
    <div class="card shadow-sm">
      <div class="card-header background-primary text-white d-flex align-items-center">
        <button mat-icon-button class="custom-back-button" (click)="goBack()">
          <mat-icon>arrow_back</mat-icon>
        </button>
        &nbsp;&nbsp;&nbsp;
        <h6 class="mb-0 main-title">
          Edit Organization Area | <span class="head-org-name">{{ orgName }}</span>
        </h6>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-3">
            <label class="mb-2 d-block"
              ><strong style="font-size: 14px">Main Selection</strong></label
            >
            <div class="border-bottom-black"></div>
            <div class="form-group mb-3 mt-2">
              <label for="province">Province</label>
              <select
                id="province"
                class="form-control form-control-sm select-op-first"
                [(ngModel)]="selectedProvince"
                (ngModelChange)="onProvinceChange($event)"
                [disabled]="loading"
              >
                <option [ngValue]="null">Select a Province</option>
                @for (province of getPdList(); track trackByStr($index, province)) {
                  <option [ngValue]="province">
                    {{ province }}
                  </option>
                }
              </select>
              @if (loading) {
                <small class="text-muted">Loading areas…</small>
              }
            </div>

            <div class="form-group mb-3">
              <label for="district">District</label>
              <select
                id="district"
                class="form-control form-control-sm"
                [(ngModel)]="selectedDistrict"
                (ngModelChange)="onDistrictChange($event)"
                [disabled]="!orgAreaDefineService.distList.length || loading"
              >
                <option [ngValue]="null">Select a District</option>
                @for (d of orgAreaDefineService.distList; track trackByStr($index, d)) {
                  <option [ngValue]="d">
                    {{ d }}
                  </option>
                }
              </select>
            </div>

            <div class="form-group mb-3">
              <label for="dsd">DSD</label>
              <select
                id="dsd"
                class="form-control form-control-sm"
                [(ngModel)]="selectedDsd"
                (ngModelChange)="onDsdChange($event)"
                [disabled]="!orgAreaDefineService.dsdList.length || loading"
              >
                <option [ngValue]="null">Select a DSD</option>
                @for (dsd of orgAreaDefineService.dsdList; track trackByStr($index, dsd)) {
                  <option [ngValue]="dsd">
                    {{ dsd }}
                  </option>
                }
              </select>
            </div>
          </div>

          <div class="col-md-5">
            <div class="row">
              <div class="gnd-area col-md-10">
                <label class="mb-2 d-block"
                  ><strong style="font-size: 14px">GN Divisions</strong></label
                >
                <div class="border-bottom-black"></div>
                <div class="mt-2 d-flex gap-2">
                  <input
                    type="search"
                    class="form-control form-control-sm"
                    placeholder="Search GN by name…"
                    [(ngModel)]="gnSearchTerm"
                  />
                </div>

                @if (filteredGndOptions.length && !gnSearchTerm.length) {
                  <div class="mt-2 d-flex align-items-center gap-2">
                    <label class="d-flex align-items-center gap-2 mb-0">
                      <input
                        type="checkbox"
                        [checked]="allVisibleChecked"
                        [indeterminate]="someVisibleChecked"
                        (change)="toggleSelectAllVisible($event)"
                        [disabled]="!filteredGndOptions.length"
                      />
                      <span style="font-size: 14px; font-weight: 600"> Select all </span>
                    </label>
                  </div>
                }

                <div class="overflow-section mt-2 d-flex flex-wrap">
                  @for (
                    row of filteredGndOptions;
                    track trackByGid(index, row);
                    let index = $index
                  ) {
                    <div class="mb-2 col-md-6">
                      <label class="d-flex align-items-center gap-2">
                        <input
                          type="checkbox"
                          [ngModel]="selectedGndMap[row.gid] || false"
                          (ngModelChange)="toggleGnd(row.gid, $event)"
                          [ngModelOptions]="{ standalone: true }"
                        />
                        <span style="font-size: 14px">{{ row.gnd }}</span>
                      </label>
                    </div>
                  }
                  @if (!filteredGndOptions.length && gnSearchTerm.length) {
                    <small class="text-muted"> No matching GN Divisions. </small>
                  }
                </div>
              </div>

              <div class="col-md-2">
                @if (hasAnySelected) {
                  <div class="d-flex align-items-center" style="min-height: 250px; height: 100%">
                    <button class="btn add-btn" (click)="addSelectedGnds()">
                      Add <mat-icon>chevron_right</mat-icon>
                    </button>
                  </div>
                }
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="gnd-areas-for-org w-100">
              <label class="mb-2 d-block"
                ><strong style="font-size: 14px">Permitted Areas</strong></label
              >
              <div class="border-bottom-black"></div>

              <div class="row g-2 mt-2">
                <div class="col-6">
                  <input
                    type="search"
                    class="form-control form-control-sm"
                    placeholder="Search GN by name…"
                    [(ngModel)]="searchAddedGNTerm"
                  />
                </div>

                <div class="col-3">
                  <select
                    class="form-control form-control-sm"
                    [ngModel]="filterAddedDist"
                    (ngModelChange)="onFilterDistChange($event)"
                    [ngModelOptions]="{ standalone: true }"
                  >
                    <option [ngValue]="null">All Districts</option>
                    @for (d of addedDistOptions; track trackByStr($index, d)) {
                      <option [ngValue]="d">
                        {{ d }}
                      </option>
                    }
                  </select>
                </div>

                <div class="col-3">
                  <select
                    class="form-control form-control-sm"
                    [ngModel]="filterAddedDsd"
                    (ngModelChange)="filterAddedDsd = $event"
                    [disabled]="!addedDsdOptions.length"
                    [ngModelOptions]="{ standalone: true }"
                  >
                    <option [ngValue]="null">All DSDs</option>
                    @for (dsd of addedDsdOptions; track trackByStr($index, dsd)) {
                      <option [ngValue]="dsd">
                        {{ dsd }}
                      </option>
                    }
                  </select>
                </div>

                <div class="overflow-section mt-2">
                  <ul class="list-group mb-3">
                    @for (r of filteredAddedGnds; track trackByGid($index, r)) {
                      <li
                        class="list-group-item d-flex justify-content-between align-items-center gn-label"
                      >
                        <span>
                          {{ r.gnd }}
                          <small class="text-muted">({{ r.dsd }} • {{ r.dist }} )</small>
                        </span>
                        <div class="d-flex align-items-center">
                          <span class="badge bg-light text-dark">GID: {{ r.gid }}</span>
                          <mat-icon
                            class="text-danger material-icons-custom remove-item-btn"
                            (click)="removeSingleGnd(r.gid)"
                            >delete</mat-icon
                          >
                        </div>
                      </li>
                    }
                  </ul>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                  <button
                    type="button"
                    mat-icon-button
                    class="primary-bg-btn"
                    style="background-color: #dc3545 !important; width: 120px"
                    (click)="removeAllAddedGnds()"
                    [disabled]="loading"
                  >
                    <mat-icon>delete</mat-icon> Remove All
                  </button>
                  <button
                    type="button"
                    mat-icon-button
                    class="primary-bg-btn"
                    (click)="applyAddedGnds()"
                    [disabled]="loading"
                  >
                    <mat-icon>save</mat-icon> Save
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</file>

<file path="src/app/admin/organizations/organization-edit/organization-edit.component.html">
<app-user-authenticator></app-user-authenticator>

<div class="header-container">
  <app-admin-header></app-admin-header>
</div>

<div class="admin-main-body">
  <div class="side-panel-container">
    <app-admin-side-bar></app-admin-side-bar>
  </div>

  <div class="tab-container">
    <div class="card shadow-sm">
      <div class="card-body">
        @if (!edit_details_show) {
          <div class="card shadow-sm">
            <div class="card-header background-primary text-white">
              <button mat-icon-button class="custom-back-button" (click)="goBack()">
                <mat-icon>arrow_back</mat-icon>
              </button>
              &nbsp;&nbsp;&nbsp;
              <h6 class="mb-0 main-title">About Organization</h6>
            </div>
            <div class="card-body d-flex justify-content-center">
              <div class="w-100 px-4" style="max-width: 600px">
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Name:</strong>
                  <span>{{ organizationForm.get('display_name')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Permit Start:</strong>
                  <span>{{ organizationForm.get('permit_start_date')?.value || '-' }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Permit End:</strong>
                  <span>{{ organizationForm.get('permit_end_date')?.value || '-' }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Director:</strong>
                  <span>{{ organizationForm.get('director')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Contact No:</strong>
                  <span>{{ organizationForm.get('contact_no')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Email:</strong>
                  <span>{{ organizationForm.get('org_email')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Address:</strong>
                  <span>{{ organizationForm.get('org_address')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Subscription Plan:</strong>
                  <span>{{ planLabel(organizationForm.get('subscription_plan')?.value) }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                  <strong>Users Limit:</strong>
                  <span>{{ organizationForm.get('users_limit')?.value }}</span>
                </div>
                <div class="mb-2 d-flex justify-content-end">
                  <button
                    mat-icon-button
                    matSuffix
                    (click)="getEdit()"
                    class="primary-custom-sm-btn"
                  >
                    <mat-icon>edit</mat-icon> Edit
                  </button>
                </div>
              </div>
            </div>
          </div>
        }

        <!-- EDIT VIEW -->
        @if (edit_details_show) {
          <div class="card shadow-sm">
            <div class="card-header background-primary text-white">
              <button mat-icon-button class="custom-back-button" (click)="goBack()">
                <mat-icon>arrow_back</mat-icon>
              </button>
              &nbsp;&nbsp;&nbsp;
              <h6 class="mb-0 main-title">Edit Organization</h6>
            </div>
            <div class="card">
              <div class="card-body">
                <form [formGroup]="organizationForm" class="w-100 px-4">
                  <div class="row">
                    <div class="form-group mb-3 col-md-6">
                      <label for="display_name">Name</label>
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        id="display_name"
                        placeholder="Enter Name"
                        formControlName="display_name"
                        required
                      />
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="permit_start_date">Permit Start</label>
                      <input
                        type="date"
                        class="form-control form-control-sm"
                        id="permit_start_date"
                        formControlName="permit_start_date"
                      />
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="permit_end_date">Permit End</label>
                      <input
                        type="date"
                        class="form-control form-control-sm"
                        id="permit_end_date"
                        formControlName="permit_end_date"
                      />
                    </div>
                    <div class="form-group mb-3 col-md-6">
                      <label for="director">Director</label>
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        id="director"
                        placeholder="Enter Director Name"
                        formControlName="director"
                      />
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="contact_no">Contact Number</label>
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        id="contact_no"
                        placeholder="Enter Contact Number"
                        formControlName="contact_no"
                      />
                      @if (
                        organizationForm.get('contact_no')?.invalid &&
                        organizationForm.get('contact_no')?.touched
                      ) {
                        <div class="text-danger">
                          @if (organizationForm.get('contact_no')?.errors?.['pattern']) {
                            <small> Enter a valid 10-digit mobile number starting with 0. </small>
                          }
                        </div>
                      }
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="org_email">Email</label>
                      <input
                        type="email"
                        class="form-control form-control-sm"
                        id="org_email"
                        placeholder="Enter Email"
                        formControlName="org_email"
                        (input)="formatEmail()"
                      />
                      @if (
                        organizationForm.get('org_email')?.invalid &&
                        organizationForm.get('org_email')?.touched
                      ) {
                        <div class="text-danger">
                          @if (organizationForm.get('org_email')?.errors?.['email']) {
                            <small> Incorrect email format. </small>
                          }
                        </div>
                      }
                    </div>
                    <div class="form-group mb-3 col-md-6">
                      <label for="org_address">Address</label>
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        id="org_address"
                        placeholder="Enter Address"
                        formControlName="org_address"
                      />
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="subscription_plan">Subscription Plan</label>
                      <select
                        class="form-control form-control-sm"
                        id="subscription_plan"
                        formControlName="subscription_plan"
                        required
                      >
                        <option value="" disabled selected>Select Plan</option>
                        @for (plan of subscriptionPlans; track plan) {
                          <option [value]="plan.value">
                            {{ plan.label }}
                          </option>
                        }
                      </select>
                    </div>
                    <div class="form-group mb-3 col-md-3">
                      <label for="users_limit">Users Limit</label>
                      <input
                        type="number"
                        class="form-control form-control-sm"
                        id="users_limit"
                        placeholder="Enter User Limit"
                        formControlName="users_limit"
                      />
                      @if (
                        organizationForm.get('users_limit')?.invalid &&
                        organizationForm.get('users_limit')?.touched
                      ) {
                        <div class="text-danger">
                          @if (organizationForm.get('users_limit')?.errors?.['min']) {
                            <small> Users limit must be at least 1. </small>
                          }
                        </div>
                      }
                    </div>
                  </div>
                  <div class="form-group d-flex justify-content-end mt-3">
                    <button
                      mat-icon-button
                      (click)="editOrganization()"
                      class="primary-bg-btn"
                      [disabled]="organizationForm.invalid || loading"
                    >
                      <mat-icon>save</mat-icon> Update
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        }
      </div>
    </div>
  </div>
</div>
</file>

